---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Link from '../components/mdxComponents/Link.astro';
import WorkCard from '../components/WorkCard.astro';
import ContactSection from '../components/ContactSection.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import { ClientRouter } from "astro:transitions";

const works = await getCollection('works', ({ data }) => data.publish);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
        <ClientRouter />
	</head>
	<body class="footer-reveal bg-backgroundcolor">
		<script is:inline>
			(function applyIndexEntrance() {
				var fromWork = document.referrer.indexOf('/works/') !== -1 || sessionStorage.getItem('skipIndexAnimations') === '1';
				var target = document.body;
				if (fromWork) {
					target.classList.add('returned-from-work');
					sessionStorage.removeItem('skipIndexAnimations');
				} else {
					target.classList.add('animate-in');
				}
			})();
			function ensureIndexEntrance() {
				if (window.location.pathname !== '/') return;
				var fromWork = sessionStorage.getItem('skipIndexAnimations') === '1';
				var el = document.body;
				var root = document.documentElement;
				if (fromWork) {
					el.classList.add('returned-from-work');
					root.classList.add('returned-from-work');
					sessionStorage.removeItem('skipIndexAnimations');
				} else if (!el.classList.contains('returned-from-work') && !el.classList.contains('animate-in')) {
					el.classList.add('animate-in');
					root.classList.add('animate-in');
				}
			}
			// After view-transition swap, body may be new; re-apply class on live document
			document.addEventListener('astro:page-load', ensureIndexEntrance);
			requestAnimationFrame(function() { requestAnimationFrame(ensureIndexEntrance); });
		</script>
		<main class="footer-reveal-content w-full px-20">
      <Header />
    <section id="Intro-text">
      <p class="index-intro text-syoro font-serif text-xl md:text-2xl w-full sm:w-2/3 md:w-1/2 mt-0.5">I design and prototype systems that help people stay consistent over time. <span>Currently building something cool at <Link href="https://nordeus.com/" class="text-link">Nordeus.</Link></span></p>
    </section>
    <section
      class="rounded-xl bg-white dark:bg-cardbg p-5 mt-10 work-cards-container"
      id="Works"
    >
      <h2 class="text-syoro opacity-50 font-sans text-lg uppercase">Selected works</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 mt-5">
        {works.map((entry) => (
          <div
            class="work-card-intro"
            transition:name={`work-${entry.id.replace(/\s+/g, '-')}`}
          >
            <WorkCard entry={entry} />
          </div>
        ))}
      </div>
      <h2 class="text-syoro opacity-50 font-sans text-lg uppercase rotate-180">Selected works</h2>
    </section>
    <ContactSection />
		</main>

		<Footer />
	</body>
</html>

<style>
  /* Default: hidden until animate-in or returned-from-work */
  .index-intro,
  .work-cards-container {
    opacity: 0;
  }

  /* First visit: run entrance animations */
  body.animate-in .index-intro {
    animation: HeroSectionIntro 0.7s ease-in-out 0.3s forwards;
  }
  body.animate-in .work-cards-container {
    animation: selectedSectionIntro 0.7s ease-in-out 0.3s forwards;
    animation-delay: 0.8s;
  }

  /* Return from work: show immediately, no animation (html + body for view-transition swap) */
  :global(html.returned-from-work) .index-intro,
  :global(html.returned-from-work) .work-cards-container,
  body.returned-from-work .index-intro,
  body.returned-from-work .work-cards-container {
    animation: none;
    opacity: 1;
    transform: none;
  }

  @keyframes HeroSectionIntro {
    from {
      opacity: 0;
      transform: translateY(-20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes selectedSectionIntro {
    from {
      opacity: 0;
      transform: translateY(70px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>


