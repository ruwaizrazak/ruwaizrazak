---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Link from '../components/mdxComponents/Link.astro';
import WorkCard from '../components/WorkCard.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import { ClientRouter } from "astro:transitions";

const works = await getCollection('works', ({ data }) => data.publish);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
        <ClientRouter />
	</head>
	<body class="bg-backgroundcolor">
		<Header />
		<main class="w-full px-20">
    <section id="Intro-text">
      <p class="text-syoro font-serif text-2xl w-1/2 mt-0.5 opacity-0" style="animation: HeroSectionIntro 0.6s ease-out 0.2s forwards;">I design and prototype systems that help people stay consistent over time. <span>Currently building something cool at <Link href="https://nordeus.com/" class="text-link">Nordeus.</Link></span></p>
    </section>
    <section
      class="rounded-xl bg-white p-5 mt-10 work-cards-container"
      id="Works"
      style="animation: selectedSectionIntro 0.6s ease-out 0.2s forwards;"
    >
      <h2 class="text-syoro opacity-50 font-sans text-lg uppercase">Selected works</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 mt-5">
        {works.map((entry, i) => (
          <div
            class="work-card-intro opacity-0"
            style={`animation: workCardIntro 0.5s ease-out forwards; animation-delay: ${400 + i * 350}ms;`}
          >
            <WorkCard entry={entry} />
          </div>
        ))}
      </div>
    </section>
		</main>
		<Footer />
	</body>
</html>

<style>
@keyframes HeroSectionIntro {
    from {
      opacity: 0;
      transform: translateY(-20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes selectedSectionIntro {
    from {
      opacity: 0;
      transform: translateY(50px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes workCardIntro {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

