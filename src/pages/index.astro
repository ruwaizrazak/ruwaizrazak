---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import IntroSection from '../components/IntroSection.astro';
import SelectedWorksSection from '../components/SelectedWorksSection.astro';

import CustomCursor from '../components/CustomCursor.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import { ClientRouter } from "astro:transitions";

const works = await getCollection('works', ({ data }) => data.publish);
// LEARN: getCollection order is not guaranteed — sort by id to match the
// numeric file-name prefixes (01Farmville3, 02EmpiresAndAllies, 03DeerHunter2018)
works.sort((a, b) => a.id.localeCompare(b.id));
---

<!doctype html>
<html lang="en" transition:animate="fade">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
        <ClientRouter />
	</head>
	<body class="footer-reveal bg-backgroundcolor">
		<!--
			Entrance animation gate (is:inline — must run synchronously before first
			paint to prevent FOUC. Module scripts are deferred, so this cannot be
			an import). Adds 'animate-in' on first visit or 'returned-from-work'
			when navigating back from a work page.
		-->
		<script is:inline>
			(function applyIndexEntrance() {
				var fromWork = document.referrer.indexOf('/works/') !== -1 || sessionStorage.getItem('skipIndexAnimations') === '1';
				var target = document.body;
				if (fromWork) {
					target.classList.add('returned-from-work');
					sessionStorage.removeItem('skipIndexAnimations');
				} else {
					target.classList.add('animate-in');
				}
			})();
		</script>

		<!-- Re-apply entrance classes after view-transition page swaps (module script) -->
		<script>
			import { ensureIndexEntrance } from '../scripts/index-entrance';
			document.addEventListener('astro:page-load', ensureIndexEntrance);
			requestAnimationFrame(() => { requestAnimationFrame(ensureIndexEntrance); });
		</script>

		<main class="footer-reveal-content w-full px-6 md:px-12 lg:px-20">
      <Header />
      <IntroSection />
      <SelectedWorksSection works={works} />
		</main>

		<Footer />
		<CustomCursor />
	</body>
</html>
