---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';
import { render } from 'astro:content';
import CustomCursor from '../../components/CustomCursor.astro';
import NotePostHero from '../../components/NotePostHero.astro';

const livePosts = await getCollection('live', ({ data }) => data.publish === true);
const sortedPosts = livePosts.sort((a, b) => {
  const dateA = new Date(a.data.date);
  const dateB = new Date(b.data.date);
  return dateB.getTime() - dateA.getTime();
});

const nowPost = sortedPosts[0];
const thenPosts = sortedPosts.slice(1);
const nowContent = nowPost ? await render(nowPost) : null;
const thenContents = await Promise.all(thenPosts.map(post => render(post)));

const proseClasses = `prose prose-neutral prose-lg dark:prose-invert max-w-3xl prose-headings:font-sans prose-p:font-serif prose-p:text-syoro prose-p:leading-relaxed prose-img:w-[95%] prose-img:aspect-auto prose-headings:text-syoro prose-h1:text-5xl md:prose-h1:text-6xl prose-h1:font-medium prose-h2:text-4xl md:prose-h2:text-5xl prose-h2:font-medium prose-h3:text-3xl md:prose-h3:text-4xl prose-h4:text-2xl md:prose-h4:text-3xl prose-h4:font-medium prose-h5:text-xl md:prose-h5:text-2xl prose-h5:font-medium prose-strong:text-syoro prose-strong:font-bold prose-blockquote:font-handwriting prose-blockquote:italic prose-blockquote:text-konpeki prose-blockquote:border-konpeki prose-blockquote:text-2xl prose-blockquote:leading-relaxed prose-blockquote:pl-6 prose-ul:font-serif prose-li:font-serif prose-ul:list-disc prose-ol:list-decimal text-lg md:text-xl prose-h1:mt-10 md:prose-h1:mt-20 prose-h2:mt-8 md:prose-h2:mt-16 prose-h3:mt-6 md:prose-h3:mt-12 prose-h4:mt-3 md:prose-h4:mt-6 prose-headings:mb-6 prose-a:text-link prose-a:underline prose-a:hover:line-through prose-a:underline-offset-8`;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<CustomCursor />
	</head>
	<body class="footer-reveal bg-backgroundcolor">
		<div class="footer-reveal-content">
		
		<main class="px-20">
			<Header />
			<NotePostHero
				title="Now"
				description="Whats happening or rather what am I doing currently?"
				pubDate={new Date(nowPost.data.date)}
				tags={[]}
			/>
			<div class="note-main-wrapper pt-20 relative z-10 bg-backgroundcolor w-screen max-w-[100vw] ml-[calc(50%-50vw)]">
				{nowPost && nowContent && (
					<div class="pb-20 w-full sm:w-[90%] lg:w-[90%] xl:w-[80%] 2xl:w-[70%] mx-auto px-20">
						<div class="flex flex-col gap-4">
							<div class="flex items-center gap-4">
								<span class="shrink-0">
									<div class="h-8 w-8 rounded-4xl border-2 border-konpeki p-1 ">
										<div class="w-full h-full rounded-4xl bg-konpeki"></div>
									</div>
								</span>
								<h2 class="text-5xl">{nowPost.data.Month}</h2>
							</div>
						</div>
						<p class="mx-12 text-xl mt-2 mb-5 font-sans bg-white">{nowPost.data.OneLiner}</p>
						<div class={`mx-12 ${proseClasses}`}>
							<nowContent.Content />
						</div>
					</div>
				)}
				{thenPosts.length > 0 && (
					<>
						
						<hr class="w-full my-8 border-stone-100">
						<div class="space-y-8 pb-20 w-full sm:w-[90%] lg:w-[90%] xl:w-[80%] 2xl:w-[70%] mx-auto px-20">
							<h1 class="text-7xl">Then ...</h1>
							{thenPosts.map((post, index) => {
								const Content = thenContents[index]?.Content;
								return (
									<div class="border-b-2 border-stone-100">
										<div class="flex items-center gap-4">
											<div class="h-8 w-8 rounded-4xl border-4 border-konpeki"></div>
											<h2 class="text-5xl">{post.data.Month}</h2>
										</div>
										<p class="mx-12 text-xl mt-2 mb-5 font-sans">{post.data.OneLiner}</p>
										<div class={`mx-12 ${proseClasses}`}>
											{Content && <Content />}
										</div>
									</div>
								);
							})}
						</div>
					</>
				)}
			</div>
		</main>
		</div>
		<Footer />
		<!-- Scroll animations: hero overlap, fade-out, and zoom -->
		<script>
			import { initNotePostAnimations } from '../../scripts/note-post-animations';

			document.addEventListener('astro:page-load', initNotePostAnimations);
			document.addEventListener('DOMContentLoaded', initNotePostAnimations);
		</script>
	</body>
</html>
