---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';
import { render } from 'astro:content';
import CustomCursor from '../../components/CustomCursor.astro';
import { ClientRouter } from 'astro:transitions';
import NotePostHero from '../../components/NotePostHero.astro';
import { proseClasses } from '../../utils/proseClasses';
import { pageType } from '../../styles/typography';

const livePosts = await getCollection('live', ({ data }) => data.publish === true);
const sortedPosts = livePosts.sort((a, b) => {
  const dateA = new Date(a.data.date);
  const dateB = new Date(b.data.date);
  return dateB.getTime() - dateA.getTime();
});

const nowPost = sortedPosts[0];
const thenPosts = sortedPosts.slice(1);
const nowContent = nowPost ? await render(nowPost) : null;
const thenContents = await Promise.all(thenPosts.map(post => render(post)));

const liveProseClasses = `${proseClasses} prose-a:text-link prose-a:underline prose-a:hover:line-through prose-a:underline-offset-8`;
---

<!doctype html>
<html lang="en" transition:animate="fade">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<ClientRouter />
		<CustomCursor />
	</head>
	<body class="bg-backgroundcolor">
		<main class="px-20">
			<Header />
			<NotePostHero
				title="Now"
				description="Whats happening or rather what am I doing currently?"
				pubDate={new Date(nowPost.data.date)}
				tags={[]}
			/>
			<div class="note-main-wrapper pt-20 relative z-10 bg-backgroundcolor w-screen max-w-[100vw] ml-[calc(50%-50vw)]">
				{nowPost && nowContent && (
					<div class="pb-20 w-full sm:w-[90%] lg:w-[90%] xl:w-[80%] 2xl:w-[70%] max mx-auto px-5 md:px-20">
						<div class="flex flex-col gap-4">
							<div class="flex items-center gap-4">
								<span class="shrink-0">
									<div class="h-8 w-8 rounded-4xl border-2 border-konpeki p-1 ">
										<div class="w-full h-full rounded-4xl bg-konpeki"></div>
									</div>
								</span>
								<h2 class={`${pageType.subtitle} text-syoro`}>{nowPost.data.Month}</h2>
							</div>
						</div>
						<p class="mx-12 text-lg md:text-xl lg:text-2xl mt-2 mb-5 font-serif text-syoro">{nowPost.data.OneLiner}</p>
						<div class={`ml-12 ${liveProseClasses}`}>
							<nowContent.Content />
						</div>
					</div>
				)}
				{thenPosts.length > 0 && (
					<>
						
						<hr class="w-full my-8 border-stone-100">
						<div class="space-y-8 pb-20 w-full sm:w-[90%] lg:w-[90%] xl:w-[80%] 2xl:w-[70%] mx-auto px-5 md:px-20 opacity-90">
							<h1 class={`${pageType.header} text-syoro`}>Then ...</h1>
							{thenPosts.map((post, index) => {
								const Content = thenContents[index]?.Content;
								return (
									<div class="border-b-2 border-stone-100">
										<div class="flex items-center gap-4">
											<div class="h-8 w-8 rounded-4xl border-4 border-konpeki"></div>
											<h2 class={`${pageType.subtitle} text-syoro`}>{post.data.Month}</h2>
										</div>
										<p class="mx-12 text-lg md:text-xl lg:text-2xl mt-2 mb-5 font-serif text-syoro/90">{post.data.OneLiner}</p>
										<div class={`mx-12 text-syoro ${liveProseClasses}`}>
											{Content && <Content />}
										</div>
									</div>
								);
							})}
						</div>
					</>
				)}
			</div>
		</main>
		<Footer />
		<!-- Hero overlap is now CSS scroll-driven (see .note-main-wrapper in global.css) -->
	</body>
</html>
