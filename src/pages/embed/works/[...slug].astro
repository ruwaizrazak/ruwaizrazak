---
import { type CollectionEntry, getCollection } from 'astro:content';
import { render } from 'astro:content';
import ExternalLink from '../../../components/mdxComponents/ExternalLink.astro';
import BaseHead from '../../../components/BaseHead.astro';
import Image from '../../../components/mdxComponents/Image.astro';

export async function getStaticPaths() {
  const posts = await getCollection('works', ({ data }) => data.publish);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: post,
  }));
}

type Props = CollectionEntry<'works'>;
const post = Astro.props;
const { Content } = await render(post);
const { title, description, pubDate, updatedDate, heroImage } = post.data;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
    <style>
      body { margin: 0; padding: 0; background: var(--color-backgroundcolor, #fafafa); }
    </style>
  </head>
  <body class="bg-backgroundcolor">
    <article class="prose-neutral prose-lg max-w-3xl mx-auto px-6 py-8 prose-headings:font-sans prose-p:font-serif prose-p:text-syoro prose-img:w-[95%] prose-img:aspect-auto prose-headings:text-konpeki prose-h4:uppercase prose-h3:uppercase prose-strong:text-pink-500 prose-h5:uppercase prose-h4:font-bold prose-h5:font-bold prose-blockquote:font-handwriting prose-blockquote:leading-auto prose-ul:font-serif prose-li:font-serif prose-ul:list-disc prose-ol:list-decimal prose-blockquote:text-yellow-600 prose-blockquote:italic text-base md:text-lg prose-h1:mt-10 prose-h2:mt-8 prose-h3:mt-6 prose-h4:mt-3 prose-headings:mb-5">
      <h1 class="text-konpeki font-serif">{title}</h1>
      <p class="text-syoro italic text-lg">{description}</p>
      {heroImage && (
        <div class="my-8">
          <Image src={heroImage} alt="" class="w-full h-auto object-cover rounded-lg" loading="eager" />
        </div>
      )}
      <Content components={{ a: ExternalLink }} />
    </article>
  </body>
</html>
