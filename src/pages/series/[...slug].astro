---
import { getCollection, render } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import NotesPost from '../../layouts/notesPost.astro';
import NotePostHero from '../../components/NotePostHero.astro';
import SeriesCard from '../../components/SeriesCard.astro';
import CustomCursor from '../../components/CustomCursor.astro';
import { getSeriesWithPosts } from '../../utils/collections';

export async function getStaticPaths() {
  const seriesIndexes = await getCollection('series', ({ data }) => data.publish);
  const seriesParts = (await getCollection('seriesPosts', ({ data }) => data.publish))
    .filter((post) => !post.id.endsWith('/index'));

  // Series index pages: drop the trailing /index from the URL
  const indexPaths = seriesIndexes.map((entry) => ({
    params: { slug: entry.id.replace(/\/index$/, '') },
    props: { kind: 'series', slug: entry.id.replace(/\/index$/, '') },
  }));

  // Series part pages: keep the full slug (e.g., series-slug/part-slug)
  const partPaths = seriesParts.map((entry) => ({
    params: { slug: entry.id },
    props: { kind: 'part', slug: entry.id },
  }));

  return [...indexPaths, ...partPaths];
}

const { kind, slug } = Astro.props as { kind: 'series' | 'part'; slug: string };

const seriesSlug = kind === 'series' ? slug : slug.split('/')[0];
const ParentSeriesSlug = seriesSlug;
const ParentSeriesSlugPretty = ParentSeriesSlug.replace(/-/g, ' ');
const ParentSeriesTitlePretty = ParentSeriesSlugPretty.replace(/\b\w/g, (c) => c.toUpperCase());

// LEARN: getSeriesWithPosts() returns each series with its sorted posts — shared with
// /series and /garden — so the index doc and its parts come from one source of truth.
// LEARN: Astro's glob loader strips `/index` from index files, so a series id is
// e.g. "portfolio-to-garden" (not ".../index"). Match on the stripped id so this
// is robust whichever form the loader yields.
const current = (await getSeriesWithPosts()).find(
  (s) => s.id.replace(/\/index$/, '') === seriesSlug
);
const seriesDoc = current;
const allParts = current?.posts ?? [];

// If this is a part page, find the specific part
const activePart = kind === 'part' ? allParts.find((p) => p.id === slug) : undefined;

// Get related posts (other parts in the same series, excluding the current one)
const relatedParts = kind === 'part' && activePart 
  ? allParts.filter((p) => p.id !== slug)
  : [];

const seoTitle = activePart ? `${activePart.data.title} · ${seriesDoc?.data.title ?? ''}` : seriesDoc?.data.title ?? 'Series';

// LEARN: OG image path derived from the current page URL — works for both
// series index pages (/series/my-series) and part pages (/series/my-series/part-1).
const ogImage = `/og${Astro.url.pathname.replace(/\/$/, '')}.png`;

// Render the active part content in frontmatter so it's available in the template
const renderResult = activePart ? await render(activePart) : null;
const Content = renderResult?.Content;
---

{kind === 'part' && activePart && Content ? (
  <NotesPost
    title={activePart.data.title}
    description={activePart.data.description}
    pubDate={activePart.data.pubDate}
    updatedDate={activePart.data.updatedDate}
    heroImage={activePart.data.heroImage}
    tags={activePart.data.tags ?? []}
    seriesPosts={relatedParts}
  >
    <Content />
  </NotesPost>
) : (
  <html lang="en">
    <head>
      <BaseHead title={seoTitle} description={seriesDoc?.data.description ?? ''} image={ogImage} />
    </head>
    <body class="bg-backgroundcolor">
      <main class="px-20">
        <Header />
        <div class="mt-20">
          <a href="/series" class="inline-block z-1">
            <div class="flex items-center gap-2 group not-prose">
              <img src="/icons/backArrow.svg" class="w-8 h-auto group-hover:rotate-20 transition-all" alt="Back" />
              <span class="uppercase font-sans font-medium text-lg">Back to Series</span>
            </div>
          </a>
        </div>

        {seriesDoc && (
          <NotePostHero
            title={seriesDoc.data.title}
            description={seriesDoc.data.description}
            pubDate={seriesDoc.data.startedDate}
            updatedDate={seriesDoc.data.lastUpdated}
            heroImage={seriesDoc.data.featuredImage}
            tags={seriesDoc.data.tags ?? []}
          />
        )}

        {/* LEARN: same full-bleed scroll-overlap wrapper as /series; SeriesCard with
            hideHeader renders only the posts grid since the hero already shows the header */}
        <div class="note-main-wrapper pt-20 relative z-10 bg-backgroundcolor w-screen max-w-[100vw] ml-[calc(50%-50vw)]">
          <div class="w-full mx-auto px-20">
            {seriesDoc && <SeriesCard series={seriesDoc} hideHeader />}
          </div>
        </div>
      </main>
      <Footer />
      <CustomCursor />
    </body>
  </html>
)}