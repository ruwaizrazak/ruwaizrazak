---
import { getMultiCollectionPosts, extractUniqueTags } from '../../utils/collections';
import IndexLayout from '../../layouts/IndexLayout.astro';

export async function getStaticPaths() {
  const { getMultiCollectionPosts } = await import('../../utils/collections');

  const allPosts = await getMultiCollectionPosts(['notes', 'essays', 'works', 'books']);
  const uniqueTags = [...new Set(allPosts.flatMap(post => post.data.tags || []))];

  return uniqueTags.map(tag => ({
    params: { tag },
    props: {
      posts: allPosts.filter(post => post.data.tags?.includes(tag)),
      tag,
      collections: ['all', 'notes', 'essays', 'works', 'books']
    }
  }));
}

const { tag, posts, collections } = Astro.props;
const allTags = ['all', ...new Set(posts.flatMap(post => post.data.tags || []))].sort();
---

<IndexLayout
  title={`${tag.charAt(0).toUpperCase() + tag.slice(1)}`}
  description={`Essays, notes and books related to ${tag}`}
  posts={posts}
  tags={[tag]}
  collections={collections}
  showCollections={true}
  showTags={false}
/>
