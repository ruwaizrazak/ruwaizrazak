---
import Layout from '../layouts/AboutLayout.astro';
import WorkCardCompact from '../components/WorkCardCompact.astro';
import { getCollection } from 'astro:content';

const works = await getCollection('works', ({ data }) => data.publish === true);

const experience = [
  {
    role: 'Senior UX Designer',
    company: 'Nordeus',
    period: '2024 – Current',
    bullets: [
      'Building features with cross-functional teams',
      'Emphasizing accessibility and data-informed solutions',
      'Maintaining cross-team design documentation to ensure seamless collaboration',
    ],
  },
  {
    role: 'Senior UX Designer',
    company: 'Zynga',
    period: '2023 – 2024',
    bullets: [
      'Redesigned navigation and first-time user experience',
      'Mentored junior staff, conducted A/B testing',
      'Maintaining cross-team design documentation to ensure seamless collaboration',
    ],
  },
  {
    role: 'UX Designer',
    company: 'Zynga',
    period: '2021 – 2023',
    bullets: [
      "Transitioned Farmville 3's UX end-to-end",
      'Revamped ad flows, built design systems in Figma and Unity',
      'Maintaining cross-team design documentation to ensure seamless collaboration',
    ],
  },
  {
    role: 'Associate UX Designer',
    company: 'Zynga',
    period: '2019 – 2021',
    bullets: [
      'Feature design, competitive analysis, Unity prefabs',
      'Collaborating with cross-functional teams and UX researchers to deliver data-informed solutions',
      'Maintaining cross-team design documentation to ensure seamless collaboration',
    ],
  },
  {
    role: 'Associate UX Designer',
    company: 'Glu Mobile',
    period: '2018 – 2019',
    bullets: [
      'Live-ops optimization, funnel analysis, usability testing',
      'Collaborating with cross-functional teams and UX researchers to deliver data-informed solutions',
      'Maintaining cross-team design documentation to ensure seamless collaboration',
    ],
  },
];
---

<Layout
	title="Curious, Multidisciplinary Designer"
	description="About Ruwaiz Razak — Designer, Learner and Builder"
>
	<!-- Hero Section -->
	<section class="py-16 md:py-24">
		<div class="flex flex-col md:flex-row gap-10 md:gap-16 items-start">
			<div class="flex-1 flex flex-col gap-6">
				<h1 class="text-3xl md:text-4xl font-serif text-syoro max-w-[80%]">
					<span class="text-konpeki">Hi, I'm Ruwaiz.</span> 
					<br>I design systems, interfaces, and interactions that help people stay engaged over time.
				</h1>
				<div class="flex flex-col gap-4 mt-4 max-w-[80%] text-xl">
					<p class="text-syoro dark:text-white/80 font-serif leading-relaxed">
						Before I knew design as a discipline, I was teaching myself HTML, building websites, and learning by making. That instinct never left. I still see code as a way to turn ideas into something real.
					</p>
					<p class="text-syoro dark:text-white/80 font-serif leading-relaxed py-5">
						Today, I work across product design, shaping onboarding, retention, live systems, and experiences.
					</p>
					<p class="text-syoro dark:text-white/80 font-serif leading-relaxed">
						I'm drawn to the layer beneath the screen: the system, the motivation, and the clarity that makes an interaction work. My practice often sits between design, strategy, data, and prototyping, because some ideas only become clear once they are tested.
					</p>
				</div>
			</div>
			<div class="w-full md:w-[40%] flex-shrink-0">
				<img
					src="/about/ruwaiz1.jpg"
					alt="Ruwaiz Razak"
					class="w-full h-auto md:h-full object-contain resize-both"
				/>
			</div>
		</div>
	</section>

	<!-- Work Experience Section -->
	<section id="work-experience" class="mt-10 md:mt-10 mb-20">
		<h2 class="text-xl font-sans font-semibold text-syoro dark:text-white/60 uppercase tracking-widest mb-8">
			Work Experience
		</h2>
		<div id="work-cards" class="flex flex-col md:flex-row md:flex-nowrap gap-0 md:overflow-visible border-t border-syoro/20 dark:border-white/20">
			{experience.map((item, i) => (
				<div class={`p-6 md:min-w-[280px] lg:min-w-1/3 md:flex-shrink-0 md:flex-1 border-syoro/20 dark:border-white/20 hover:scale-105 hover:min-w-1/2.9 hover:bg-konpeki/10 transition-all duration-200 ease-in-out ${i > 0 ? '' : ''}`}>
					<div class="flex flex-col gap-1 mb-4">
						<h2 class="text-2xl font-sans text-syoro dark:text-white uppercase leading-snug">
							{item.role}
						</h2>
						<h3 class="text-xl font-sans font-semibold text-syoro/60 dark:text-white/40 uppercase">
							{item.company} | {item.period}
						</h3>
					</div>
					<ul class="space-y-2">
						{item.bullets.map((bullet) => (
							<li class="text-xl font-serif text-syoro/80 dark:text-white/60 leading-relaxed flex gap-2">
								<span class="text-syoro/40 dark:text-white/30 mt-1 flex-shrink-0">·</span>
								<span>{bullet}</span>
							</li>
						))}
					</ul>
				</div>
			))}
		</div>
	</section>

	<!-- Selected Works Section -->
	<section class="mb-16">
		<h2 class="text-xl font-sans font-semibold text-syoro dark:text-white/60 uppercase tracking-widest">
			Selected Projects
		</h2>
		<p class="text-xl font-serif text-syoro/80 dark:text-white/60 leading-relaxed mb-8">Here are some of the projects I've worked on.</p>
		<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
			{works.map(work => (
				<WorkCardCompact
					title={work.data.title}
					role={work.data.role}
					company={work.data.company}
					duration={work.data.duration}
					heroImage={work.data.heroImage}
					url={`/works/${work.id}`}
				/>
			))}
		</div>
	</section>
</Layout>

<script>
	import { initWorkExperienceScroll } from '../scripts/work-experience-scroll';
	import { initOnLoad } from '../utils/initOnLoad';
	initOnLoad(initWorkExperienceScroll);
</script>
