---
import { type CollectionEntry, getCollection } from 'astro:content';
import { render } from 'astro:content';
import NotesPost from '../../layouts/notesPost.astro';
import Link from "../../components/mdxComponents/Link.astro"

export async function getStaticPaths() {
	const posts = await getCollection('playground');
	return posts.map((post) => {
		const parts = post.id.split('/');
		const last = parts.length > 0 ? parts[parts.length - 1] : '';
		const filename = typeof last === 'string' ? last.replace(/\.[^.]+$/, '') : '';
		return {
			params: { slug: filename.toLowerCase() },
			props: post,
		};
	});
}
type Props = CollectionEntry<'playground'>;

const post = Astro.props;
const { Content } = await render(post);
---

<NotesPost {...post.data} collection="playground" icon="/icons/playground.svg">
	<Content components={{ a: Link }} />
</NotesPost>
