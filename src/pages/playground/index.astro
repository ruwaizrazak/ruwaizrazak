---
import { getCollection } from 'astro:content';
import IndexLayout from '../../layouts/IndexLayout.astro';

const playground = await getCollection('playground', ({ data }) => data.publish === true);

const allPosts = [
  ...playground.map(post => ({ ...post, collection: 'playground' }))
].sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const allTags = ['all', ...new Set(allPosts.flatMap(post => post.data.tags || []))].sort();
---

<IndexLayout
  title="Playground"
  description="Animations, interactions, and games — small experiments and creative explorations."
  posts={allPosts}
  tags={allTags}
  icon="/icons/playground.svg"
/>
