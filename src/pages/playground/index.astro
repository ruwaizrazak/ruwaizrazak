---
import { getPublishedAndSorted, extractUniqueTags } from '../../utils/collections';
import IndexLayout from '../../layouts/IndexLayout.astro';

const allPosts = await getPublishedAndSorted('playground');
const allTags = extractUniqueTags(allPosts);
---

<IndexLayout
  title="Playground"
  description="Animations, interactions, and games — small experiments and creative explorations."
  posts={allPosts}
  tags={allTags}
  icon="/icons/playground.svg"
/>
