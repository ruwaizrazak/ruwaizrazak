
---
import { SITE_TITLE, SITE_DESCRIPTION, DEFAULT_COLLECTIONS } from '../../consts';
import { getPublishedAndSorted, extractUniqueTags } from '../../utils/collections';
import IndexLayout from '../../layouts/IndexLayout.astro';

const allNotes = await getPublishedAndSorted('notes');
const allTags = extractUniqueTags(allNotes);
---

<IndexLayout
  title="Notes"
  description="Notes are notes. They are not refined, might be incomplete, or just plain wrong. But they sure are a starting point for me to think about."
  posts={allNotes}
  tags={allTags}
  collections={DEFAULT_COLLECTIONS}
  icon="/icons/notes.svg"
/>

<style>
	.masonry-grid {
		column-gap: 1rem;
	}
	.break-inside-avoid {
		break-inside: avoid;
	}
</style>
