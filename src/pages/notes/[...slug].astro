---
import { type CollectionEntry, getCollection } from 'astro:content';
import { render } from 'astro:content';
import NotesPost from '../../layouts/notesPost.astro';
import Link from "../../components/mdxComponents/Link.astro"
import { getStaticPathsForCollection } from '../../utils/collections';

export async function getStaticPaths() {
	return getStaticPathsForCollection('notes');
}
type Props = CollectionEntry<'notes'>;

const post = Astro.props;
const { Content } = await render(post);
---

<NotesPost {...post.data} collection="notes" icon="/icons/notes.svg">
	<Content components={{ a: Link }}/>
</NotesPost>
