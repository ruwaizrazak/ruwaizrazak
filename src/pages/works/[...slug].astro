---
import { type CollectionEntry, getCollection } from 'astro:content';
import { render } from 'astro:content';
import NotesPost from '../../layouts/notesPost.astro';
import Link from '../../components/mdxComponents/Link.astro';

export async function getStaticPaths() {
	const posts = await getCollection('works');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<'works'>;

const post = Astro.props;
const { Content } = await render(post);
---

<NotesPost {...post.data} collection="works" icon="/icons/series.svg">
	<Content components={{ a: Link }}/>
</NotesPost>
