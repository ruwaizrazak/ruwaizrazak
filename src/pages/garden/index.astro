---
import { GARDEN_COLLECTIONS } from '../../consts';
import { getMultiCollectionPosts, getSeriesCards, extractUniqueTags } from '../../utils/collections';
import IndexLayout from '../../layouts/IndexLayout.astro';

const posts = await getMultiCollectionPosts(['notes', 'essays', 'books', 'playground']);

// LEARN: getSeriesCards() returns series in the card shape (with a synthetic
// pubDate from lastUpdated) so they interleave by recency with the other cards.
const seriesCards = await getSeriesCards();

const allPosts = [...posts, ...seriesCards].sort(
  (a: any, b: any) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const allTags = extractUniqueTags(allPosts);
---

<IndexLayout
  title="Garden"
  description="In a nutshell, a garden can be comprised of Essays, Books and imperfect Notes along with whatever resources I find interesting and felt might be useful at a later stage."
  posts={allPosts}
  tags={allTags}
  collections={GARDEN_COLLECTIONS}
  showCollections={true}
  icon="/icons/garden.svg"
/>
