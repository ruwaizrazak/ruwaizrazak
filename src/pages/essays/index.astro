
---
import { SITE_TITLE, SITE_DESCRIPTION, DEFAULT_COLLECTIONS } from '../../consts';
import { getPublishedAndSorted, extractUniqueTags } from '../../utils/collections';
import IndexLayout from '../../layouts/IndexLayout.astro';

const allEssays = await getPublishedAndSorted('essays');
const allTags = extractUniqueTags(allEssays);
---

<IndexLayout
  title="Essays"
  description="Essays are more refined, long written documents which are opinionated and have a message to deliver."
  posts={allEssays}
  tags={allTags}
  collections={DEFAULT_COLLECTIONS}
  icon="/icons/essays.svg"
/>

<style>
	.masonry-grid {
		column-gap: 1rem;
	}
	.break-inside-avoid {
		break-inside: avoid;
	}
</style>
