---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import NoteCard from '../components/NoteCard.astro';
import EssayCard from '../components/EssayCard.astro';
import Tag from '../components/Tag.astro';
import { ClientRouter } from "astro:transitions";


interface Props {
  title: string;
  description: string;
  posts: any[];
  tags?: string[];
  collections?: string[];
  showCollections?: boolean;
  icon?: string;
  showTags?: boolean;
}

const {
  title,
  description,
  posts,
  icon,
  tags = ['all'],
  collections = ['all'],
  showCollections = false,
  showTags = true
} = Astro.props;

const isGarden = Astro.url.pathname === '/garden' || Astro.url.pathname === '/garden/';

const currentTag = 'all';

// Sort tags with 'all' first, then alphabetically
const sortedTags = [...tags.filter(tag => tag !== 'all').sort()];
---

<!doctype html>
<html lang="en" transition:name="root" transition:animate="none">
  <head>
    <BaseHead title={title} description={description} />
    {isGarden && (
      <link href="https://fonts.googleapis.com/css2?family=Saira+Extra+Condensed:wght@100;200;300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    )}
    <ClientRouter />
  </head>

  <body class:list={[isGarden && 'garden-body', !isGarden && 'footer-reveal', 'bg-backgroundcolor','px-20']}>
  {isGarden ? (
    <>
      <Header />
      <main>
        <section class="intro-section flex flex-col items-center justify-center px-10" style="padding-bottom: 220px;">
          <h1 class="garden-heading text-center text-konpeki">THE GARDEN</h1>
          <p class="garden-description font-serif text-2xl md:text-[32px] text-center text-syoro mt-6 max-w-2xl italic">{description}</p>
        </section>

        <div class="garden-sticky-bar sticky top-0 z-40 bg-backgroundcolor/90 backdrop-blur-sm px-10 py-3 opacity-0 pointer-events-none transition-opacity duration-200" id="garden-sticky-bar">
          <div class="flex items-center gap-6 flex-wrap">
            <h2 class="garden-heading-small text-konpeki whitespace-nowrap">THE GARDEN</h2>
            <div class="topics-bar flex flex-wrap gap-3">
              {sortedTags.map((tag, index) => (
                <Tag tag={tag} isActive={false} index={index} />
              ))}
            </div>
          </div>
        </div>

        <section class="garden-cards-section px-10 pb-40">
          <div class="card-masonry columns-1 md:columns-2 lg:columns-3 2xl:columns-4 gap-6">
            {posts?.map((post) => (
              post.collection === 'essays' ? (
                <div class="garden-card-item break-inside-avoid mb-6">
                  <EssayCard
                    title={post.data.title}
                    description={post.data.description || ''}
                    pubDate={post.data.pubDate}
                    url={`/essays/${post.id}/`}
                    heroImage={post.data.heroImage}
                    maturity={post.data.maturity}
                  />
                </div>
              ) : (
                <div class="garden-card-item break-inside-avoid mb-6">
                  <NoteCard
                    title={post.data.title}
                    description={post.data.description || ''}
                    pubDate={post.data.pubDate}
                    url={`/${post.collection}/${post.id}/`}
                    maturity={post.data.maturity}
                  />
                </div>
              )
            ))}
          </div>
        </section>
      </main>

      <!-- Garden strip: fixed to bottom, shape animated by GSAP -->
      <div class="garden-strip fixed bottom-0 left-0 w-full bg-black z-50" style="height: 220px; border-radius: 50% 50% 0 0 / 110px 110px 0 0; overflow: visible;">
        <!-- Trees layer: tallest, behind everything -->
        {[0,1,2,3,4,5,6,7].map((i) => (
          <img
            src={i % 2 === 0 ? '/siteAssets/trees/Tree1.svg' : '/siteAssets/trees/Tree2.svg'}
            class="tree-item absolute z-[0] pointer-events-none"
            data-index={String(i)}
            style="left: 0; top: 0; opacity: random(0.5, 1); height: 60px; width: auto; transform: translate(-50%, -100%);"
            alt=""
          />
        ))}
        <!-- Flowers layer: shorter, in front of trees -->
        {[
          '/siteAssets/trees/flower/flower1.svg',
          '/siteAssets/trees/flower/flower2.svg',
          '/siteAssets/trees/flower/grass2.svg',
        ].map((src, i) => (
          <img
            src={src}
            class="flower-item absolute z-[0] pointer-events-none"
            data-index={String(i)}
            style="left: 0; top: 0; height: 30px; width: auto; transform: translate(-50%, -100%);"
            alt=""
          />
        ))}
        <!-- Grass canvas: procedural grass blades drawn along the curve -->
        <canvas class="grass-canvas absolute left-0 w-full z-[1] pointer-events-none"
                style="top: -15px; height: 125px;"></canvas>
        <!-- Plants layer: positioned along top oval path by JS -->
        {posts?.map((post, i) => (
          <img
            src={`/icons/${post.data.maturity ?? 'seed'}.svg`}
            class="plant-icon absolute w-7 h-auto z-[3]"
            data-index={String(i)}
            style="min-width: 28px; left: 0; top: 0; transform: translate(-50%, -100%);"
            alt=""
          />
        ))}
        <!-- Character placeholder: x by GSAP, y follows oval path -->
        <div
          class="character-placeholder absolute"
          style="top: 0; left: 20px; width: 40px; height: 50px; background: #555; border-radius: 4px; z-index: 4; transform: translate(0, 0);"
          data-walking="false"
          data-facing-right="true"
        ></div>
      </div>
    </>
  ) : (
    <>
      <main class="footer-reveal-content w-full px-20">
        <Header />
        <div class="mt-8">
          <div class="flex flex-col mt-20">
            <a href={Astro.url.pathname.includes('/garden') ? '/' : '/garden'} class="inline-block">
            <div class="flex items-center gap-2 group mb-5">
              <img src="/icons/backArrow.svg" class="w-8 h-auto group-hover:rotate-20 transition-all" alt="Back" />
              <span class="uppercase font-sans text-konpeki font-medium">Back to {Astro.url.pathname.includes('/garden') ? 'Index' : 'Garden'}</span>
            </div>
          </a>
          <div class="flex items-center gap-2">
            {icon && (
              <img src={icon} class="w-20 h-auto" alt={title} />
            )}
            <h1>{title}</h1>
          </div>

            <p class="w-full md:w-[70%] text-left text-syoro text-base md:text-lg mt-2 font-serif italic">{description}</p>
          </div>
          <div class="mt-10">
            <div class="flex flex-row gap-4 mb-4 justify-start">
              {showTags && (
                <>
                  {/* Desktop/Tablet: Tag system with show more */}
                  <div class="md:flex items-center h-9 hidden">
                    <h4 class="text-lg uppercase border-l-2 pl-1 pr-5 border-konpeki text-konpeki">Topics</h4>
                  </div>

                  <div class="hidden md:block">
                    <div class="flex flex-wrap justify-start gap-4 mr-10 mb-5">
                      {sortedTags.slice(0, 10).map((tag, index) => (
                        <Tag
                          tag={tag}
                          isActive={tag === currentTag}
                          index={index}
                        />
                      ))}
                      {sortedTags.length > 10 && (
                        <button
                          id="showMoreTags"
                          class="px-4 py-2 text-sm border border-gray-300 dark:border-card-border border-dashed transition-all duration-200 hover:-skew-x-6 hover:bg-gray-200 dark:hover:bg-gray-700"
                        >
                          +{sortedTags.length - 10} more
                        </button>
                      )}
                    </div>
                    {sortedTags.length > 10 && (
                      <div id="additionalTags" class="flex-wrap justify-start gap-4 mb-5" style="display: none;">
                        {sortedTags.slice(10).map((tag, index) => (
                          <Tag
                            tag={tag}
                            isActive={tag === currentTag}
                            index={index + 10}
                          />
                        ))}
                        <button
                          id="showLessTags"
                          class="px-4 py-2 text-sm border border-gray-300 dark:border-card-border border-dashed transition-all duration-200 hover:-skew-x-6 bg-gray-100 dark:bg-cardbg hover:bg-gray-200 dark:hover:bg-gray-700"
                        >
                          show less
                        </button>
                      </div>
                    )}
                  </div>

                  {/* Mobile: Dropdown menu */}
                  <div class="md:hidden">
                    <div class="relative inline-block">
                      <select
                        id="tagDropdown"
                        class="px-4 py-2 text-sm border border-syoro hover:bg-yellow-50 dark:hover:bg-gray-700 text-syoro cursor-pointer bg-transparent dark:bg-transparent appearance-none pr-10"
                      >
                        <option value="all">All Topics</option>
                        {sortedTags.map(tag => (
                          <option value={tag}>
                            {tag.charAt(0).toUpperCase() + tag.slice(1)}
                          </option>
                        ))}
                      </select>
                      <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-gray-500">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                        </svg>
                      </div>
                    </div>
                  </div>
                </>
              )}
              {showCollections && collections.length > 1 && (
              <div class="relative inline-block self-start">
                <select class="collection-filter px-4 py-2 text-sm border border-syoro hover:bg-yellow-50 dark:hover:bg-gray-700 text-syoro cursor-pointer bg-transparent dark:bg-transparent appearance-none pr-10">
                  {collections.map(collection => (
                    <option value={collection}>
                      {collection === 'all' ? 'All Posts' : collection.charAt(0).toUpperCase() + collection.slice(1)}
                    </option>
                  ))}
                </select>
                <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-gray-500">
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
                  </svg>
                </div>
              </div>
            )}
            </div>
            <div class="masonry-grid columns-1 md:columns-2 lg:columns-3 2xl:columns-4 gap-5 md:gap-7 lg:gap-10">
            {posts?.map((post) => (
              <div class="break-inside-avoid mb-4 post-item transition-all duration-700" data-tags={post.data.tags?.join(' ')} data-collection={post.collection}>
                {post.collection === 'essays' ? (
                  <EssayCard
                    title={post.data.title}
                    description={post.data.description || 'No description available'}
                    pubDate={post.data.pubDate}
                    url={`/essays/${post.id}/`}
                    heroImage={post.data.heroImage}
                    maturity={post.data.maturity}
                  />
                ) : (
                  <NoteCard
                    title={post.data.title}
                    description={post.data.description || 'No description available'}
                    pubDate={post.data.pubDate}
                    url={`/${post.collection}/${post.id}/`}
                    maturity={post.data.maturity}
                  />
                )}
              </div>
            ))}
            </div>
        </div>
      </main>
      <Footer />
    </>
  )}

  <script>
    import gsap from 'gsap';
    import ScrollTrigger from 'gsap/ScrollTrigger';
    gsap.registerPlugin(ScrollTrigger);

    // ═══════════════════════════════════════════════════════════════
    // GARDEN: vertical scroll with animated garden-strip
    // ═══════════════════════════════════════════════════════════════
    // Top oval path: y offset from strip top for a given x (0 = left edge). b = vertical radius of ellipse.
    function curveY(x: number, stripWidth: number, b: number): number {
      if (stripWidth <= 0 || b <= 0) return 0;
      const t = 2 * (x / stripWidth) - 1; // -1 to 1
      const inner = 1 - t * t;
      return inner <= 0 ? b : b * (1 - Math.sqrt(inner));
    }

    function positionAlongCurve(
      strip: HTMLElement,
      b: number,
      selector: string,
      transform = 'translate(-50%, -100%)'
    ) {
      const w = strip.offsetWidth;
      const elements = strip.querySelectorAll<HTMLElement>(selector);
      const n = elements.length;
      if (n === 0 || w <= 0) return;
      elements.forEach((el, i) => {
        const x = ((i + 1) / (n + 1)) * w;
        const y = curveY(x, w, b);
        el.style.left = `${x}px`;
        el.style.top = `${y}px`;
        el.style.transform = transform;
      });
    }

    function positionPlantsAlongCurve(strip: HTMLElement, b: number) {
      positionAlongCurve(strip, b, '.plant-icon');
    }

    function positionTreesAlongCurve(strip: HTMLElement, b: number) {
      positionAlongCurve(strip, b, '.tree-item');
    }

    function positionFlowersAlongCurve(strip: HTMLElement, b: number) {
      positionAlongCurve(strip, b, '.flower-item');
    }

    // Seeded pseudo-random for deterministic blade shapes (no shimmer between frames)
    function seededRandom(seed: number): number {
      const x = Math.sin(seed * 127.1) * 43758.5453;
      return x - Math.floor(x);
    }

    // Compute outward normal angle from ellipse derivative at position x
    function curveNormalAngle(x: number, w: number, b: number): number {
      if (w <= 0 || b <= 0) return -Math.PI / 2; // straight up when flat
      const t = 2 * (x / w) - 1;
      const inner = 1 - t * t;
      if (inner <= 0.001) return -Math.PI / 2;
      const dydx = (2 * b / w) * t / Math.sqrt(inner);
      return Math.atan2(-1, dydx);
    }

    // Draw procedural grass blades on canvas along the curve
    function drawGrass(canvas: HTMLCanvasElement, ctx: CanvasRenderingContext2D, stripWidth: number, b: number) {
      const canvasH = 125;
      const maxBladeH = 15;
      ctx.clearRect(0, 0, stripWidth, canvasH);

      const step = 4; // pixels between blade clusters
      const bladeColors = ['#00300e', '#003d12', '#002a0c', '#004a16', '#001f08'];

      for (let x = 0; x < stripWidth; x += step) {
        const curveYPos = curveY(x, stripWidth, b);
        // baseY follows the curve: 15px offset for blade room above, plus curve depth
        const baseY = maxBladeH + curveYPos;
        const angle = curveNormalAngle(x, stripWidth, b);

        // Draw 2-3 blades per cluster
        const bladeCount = 2 + Math.floor(seededRandom(x * 0.73) * 2);
        for (let j = 0; j < bladeCount; j++) {
          const seed = x * 13.7 + j * 47.3;
          const bladeHeight = 6 + seededRandom(seed) * 9;
          const lean = (seededRandom(seed + 1) - 0.5) * 0.4;
          const width = 1.5 + seededRandom(seed + 2) * 2.5;

          const bladeAngle = angle + lean;
          const tipX = x + Math.cos(bladeAngle) * bladeHeight;
          const tipY = baseY + Math.sin(bladeAngle) * bladeHeight;
          const cpX = x + Math.cos(bladeAngle + lean * 0.5) * bladeHeight * 0.6;
          const cpY = baseY + Math.sin(bladeAngle + lean * 0.5) * bladeHeight * 0.6;

          ctx.beginPath();
          ctx.moveTo(x - width / 2, baseY);
          ctx.quadraticCurveTo(cpX, cpY, tipX, tipY);
          ctx.quadraticCurveTo(cpX + width * 0.3, cpY, x + width / 2, baseY);
          ctx.closePath();

          ctx.fillStyle = bladeColors[Math.floor(seededRandom(seed + 3) * bladeColors.length)];
          ctx.fill();
        }
      }
    }

    function initGrassCanvas(canvas: HTMLCanvasElement): CanvasRenderingContext2D | null {
      const ctx = canvas.getContext('2d');
      return ctx;
    }

    function sizeGrassCanvas(canvas: HTMLCanvasElement, ctx: CanvasRenderingContext2D, stripWidth: number) {
      const dpr = window.devicePixelRatio || 1;
      canvas.width = stripWidth * dpr;
      canvas.height = 125 * dpr;
      canvas.style.width = `${stripWidth}px`;
      canvas.style.height = '125px';
      ctx.setTransform(1, 0, 0, 1, 0, 0);
      ctx.scale(dpr, dpr);
    }

    function initGarden() {
      if (!document.querySelector('.garden-body')) return;

      ScrollTrigger.getAll().forEach(st => st.kill());

      const strip = document.querySelector('.garden-strip') as HTMLElement;
      const character = document.querySelector('.character-placeholder') as HTMLElement;
      const stickyBar = document.getElementById('garden-sticky-bar');
      const grassCanvas = document.querySelector('.grass-canvas') as HTMLCanvasElement;
      const grassCtx = grassCanvas ? initGrassCanvas(grassCanvas) : null;

      let stripCurveB = 110;
      const B_MAX = 110;

      if (strip) {
        positionPlantsAlongCurve(strip, stripCurveB);
        positionTreesAlongCurve(strip, stripCurveB);
        positionFlowersAlongCurve(strip, stripCurveB);
        if (grassCanvas && grassCtx) {
          sizeGrassCanvas(grassCanvas, grassCtx, strip.offsetWidth);
          drawGrass(grassCanvas, grassCtx, strip.offsetWidth, stripCurveB);
        }
        window.addEventListener('resize', () => {
          positionPlantsAlongCurve(strip, stripCurveB);
          positionTreesAlongCurve(strip, stripCurveB);
          positionFlowersAlongCurve(strip, stripCurveB);
          if (grassCanvas && grassCtx) {
            sizeGrassCanvas(grassCanvas, grassCtx, strip.offsetWidth);
            drawGrass(grassCanvas, grassCtx, strip.offsetWidth, stripCurveB);
          }
        });
      }

      if (character && strip) {
        const w = strip.offsetWidth;
        gsap.set(character, { x: 30, y: curveY(120, w, B_MAX) - 50 });
      }

      // Show sticky bar only when garden-cards-section reaches center of viewport
      if (stickyBar) {
        ScrollTrigger.create({
          trigger: '.garden-cards-section',
          start: 'top center',
          end: 'top top',
          onEnter: () => {
            stickyBar.classList.remove('opacity-0', 'pointer-events-none');
            stickyBar.classList.add('opacity-100');
          },
          onLeaveBack: () => {
            stickyBar.classList.add('opacity-0', 'pointer-events-none');
            stickyBar.classList.remove('opacity-100');
          }
        });
      }

      // Garden strip animation: shrinks as user scrolls past intro; plants + character follow curve
      ScrollTrigger.create({
        id: 'intro-strip',
        trigger: '.intro-section',
        start: 'top top',
        end: 'bottom top',
        scrub: true,
        onUpdate(self) {
          const p = self.progress;
          stripCurveB = B_MAX * (1 - p);

          gsap.set('.garden-strip', {
            height: 220 - 190 * p,
            borderRadius: `${50 * (1 - p)}% ${50 * (1 - p)}% 0 0 / ${110 * (1 - p)}px ${110 * (1 - p)}px 0 0`,
          });

          gsap.set('.garden-description', {
            opacity: 1 - p,
          });

          if (strip) {
            positionPlantsAlongCurve(strip, stripCurveB);
            positionTreesAlongCurve(strip, stripCurveB);
            positionFlowersAlongCurve(strip, stripCurveB);
            if (grassCanvas && grassCtx) {
              drawGrass(grassCanvas, grassCtx, strip.offsetWidth, stripCurveB);
            }
          }
          if (character) {
            const w = strip?.offsetWidth ?? window.innerWidth;
            const charX = 20 + (gsap.getProperty(character, 'x') as number);
            gsap.set(character, { y: curveY(charX, w, stripCurveB) - 50 });
          }
        }
      });

      // Character walks across the strip as user scrolls through cards; y follows oval path
      if (character) {
        ScrollTrigger.create({
          trigger: '.garden-cards-section',
          start: 'top 50%',
          end: 'bottom bottom',
          scrub: 1,
          onUpdate(self) {
            const p = self.progress;
            const vw = window.innerWidth;
            const charStartX = 10;
            const charEndX = vw - 100;
            const charX = charStartX + p * (charEndX - charStartX);
            const introTrigger = ScrollTrigger.getById('intro-strip');
            const b = introTrigger ? B_MAX * (1 - introTrigger.progress) : B_MAX;
            const y = curveY(20 + charX, vw, b) - 50;

            gsap.set(character, { x: charX, y });

            const velocity = self.getVelocity();
            character.dataset.walking = String(Math.abs(velocity) > 10);
            character.dataset.facingRight = String(velocity >= 0);
          }
        });
      }

      ScrollTrigger.refresh();
    }

    // ═══════════════════════════════════════════════════════════════
    // NON-GARDEN: Tag/collection filtering for masonry grid
    // ═══════════════════════════════════════════════════════════════
    function initializeFilters() {
      const collectionFilter = document.querySelector('.collection-filter') as HTMLSelectElement;
      const tagDropdown = document.querySelector('#tagDropdown') as HTMLSelectElement;
      const showMoreBtn = document.querySelector('#showMoreTags') as HTMLButtonElement;
      const showLessBtn = document.querySelector('#showLessTags') as HTMLButtonElement;
      const additionalTags = document.querySelector('#additionalTags') as HTMLElement;
      const posts = document.querySelectorAll('.post-item') as NodeListOf<HTMLElement>;

      if (!posts.length) return; // Not a masonry page

      let currentCollection = 'all';
      let currentTag = 'all';

      posts.forEach(post => {
        post.style.display = 'block';
      });

      if (showMoreBtn && additionalTags) {
        showMoreBtn.addEventListener('click', () => {
          additionalTags.style.display = 'flex';
          showMoreBtn.style.display = 'none';
        });
      }

      if (showLessBtn && additionalTags && showMoreBtn) {
        showLessBtn.addEventListener('click', () => {
          additionalTags.style.display = 'none';
          showMoreBtn.style.display = 'inline-block';
        });
      }

      if (tagDropdown) {
        tagDropdown.value = 'all';
        tagDropdown.addEventListener('change', (e) => {
          const target = e.target as HTMLSelectElement;
          currentTag = target.value;
          filterPosts();
        });
      }

      if (collectionFilter) {
        collectionFilter.value = 'all';
        collectionFilter.addEventListener('change', (e) => {
          const target = e.target as HTMLSelectElement;
          currentCollection = target.value;
          filterPosts();
        });
      }

      const tagLinks = document.querySelectorAll('a[data-tag]') as NodeListOf<HTMLAnchorElement>;
      tagLinks.forEach(link => {
        link.addEventListener('click', (e) => {
          e.preventDefault();
          const tag = link.dataset.tag;

          tagLinks.forEach(l => l.classList.remove('active'));
          link.classList.add('active');

          if (tagDropdown && tag) {
            tagDropdown.value = tag;
          }

          if (tag) {
            currentTag = tag;
            filterPosts();
          }
        });
      });

      function filterPosts() {
        posts.forEach(post => {
          const postCollection = post.dataset.collection;
          const postTags = post.dataset.tags ? post.dataset.tags.split(' ') : [];

          const matchesCollection = currentCollection === 'all' || postCollection === currentCollection;
          const matchesTag = currentTag === 'all' || postTags.includes(currentTag);

          if (matchesCollection && matchesTag) {
            post.style.display = 'block';
          } else {
            post.style.display = 'none';
          }
        });
      }

      filterPosts();
    }

    // ═══════════════════════════════════════════════════════════════
    // INIT: Run the right logic based on which page is loaded
    // ═══════════════════════════════════════════════════════════════
    function init() {
      requestAnimationFrame(() => {
        initGarden();
        initializeFilters();
      });
    }

    document.addEventListener('DOMContentLoaded', init);
    document.addEventListener('astro:page-load', init);
    window.addEventListener('pageshow', init);
  </script>
  </body>
</html>

<style>
  /* Shared styles */
  .masonry-grid {
    column-gap: 1rem;
  }
  .break-inside-avoid {
    break-inside: avoid;
  }
  a:hover {
    text-decoration: line-through;
    text-decoration-style: wavy;
  }
  .active {
    text-decoration-thickness: .05em;
    text-decoration: line-through;
    text-decoration-style: wavy;
  }

  /* Garden: vertical scroll with animated strip */
  .garden-heading {
    font-family: 'Saira Extra Condensed', 'Saira Condensed', sans-serif;
    font-size: clamp(56px, 10vw, 96px);
    font-weight: 600;
    text-transform: uppercase;
    transform-origin: center top;
    letter-spacing: 0.02em;
    line-height: 1;
  }
  .garden-heading-small {
