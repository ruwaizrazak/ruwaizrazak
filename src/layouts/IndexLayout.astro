---
import BaseHead from '../components/BaseHead.astro';
import GardenView from '../components/garden/GardenView.astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description: string;
  posts: any[];
  tags?: string[];
  collections?: string[];
  showCollections?: boolean;
  icon?: string;
  showTags?: boolean;
}

const {
  title,
  description,
  posts,
  tags = ['all'],
} = Astro.props;

const sortedTags = [...tags.filter(tag => tag !== 'all').sort()];
---

<!doctype html>
<html lang="en" transition:name="root" transition:animate="none">
  <head>
    <BaseHead title={title} description={description} />
    <link
      href="https://fonts.googleapis.com/css2?family=Saira+Extra+Condensed:wght@100;200;300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
  </head>

  <body class="garden-body bg-backgroundcolor px-5 md:px-20">
    <GardenView
      title={title}
      description={description}
      posts={posts}
      sortedTags={sortedTags}
    />
  </body>
</html>

<script>
  import { initGarden } from '../scripts/garden/gardenAnimation';
  import { initializeFilters } from '../scripts/listing/listingFilters';

  function init() {
    requestAnimationFrame(() => {
      initGarden();
      initializeFilters();
    });
  }

  document.addEventListener('DOMContentLoaded', init);
  document.addEventListener('astro:page-load', init);
  window.addEventListener('pageshow', init);
</script>
