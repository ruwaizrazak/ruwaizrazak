---
import type { CollectionEntry } from 'astro:content';
import { ClientRouter } from 'astro:transitions';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import NoteMain from '../components/NoteMain.astro';
import NotePostHero from '../components/NotePostHero.astro';
import RelatedNotes from '../components/RelatedNotes.astro';
import Webmentions from '../components/Webmentions.astro';
import CustomCursor from '../components/CustomCursor.astro';

type LayoutProps = CollectionEntry<'notes'>['data'] & {
  transitionName?: string;
  seriesPosts?: any[];
};

const { title, description, pubDate, updatedDate, heroImage, tags = [], maturity, transitionName, seriesPosts } = Astro.props as LayoutProps;
const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const workTransitionStyle = transitionName
  ? `::view-transition-new(${transitionName}){animation:work-scale-in .4s cubic-bezier(.32,.72,0,1)}`
  : '';

// LEARN: BlogPosting schema tells Google this is an article, enabling
// rich results (date, author) in search — dateModified improves freshness signals
const blogPostingSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  url: canonicalURL,
  ...(heroImage && { image: new URL(heroImage, Astro.site).href }),
  author: {
    '@type': 'Person',
    name: 'Ruwaiz Razak',
    url: Astro.site,
  },
};
---

<html lang="en" class="scroll-smooth">
  <head>
    <BaseHead title={title} description={description} schema={blogPostingSchema} />
    <ClientRouter />
    {workTransitionStyle && <style is:global set:html={workTransitionStyle} />}
    <script is:inline>
      if (sessionStorage.getItem('nav-from-related') === '1') {
        sessionStorage.removeItem('nav-from-related');
        var s = document.createElement('style');
        s.textContent = '\
          @keyframes slide-in-from-right { from { transform: translateX(100%); } to { transform: translateX(0); } }\
          @keyframes slide-out-to-left { from { transform: translateX(0); opacity: 1; } to { transform: translateX(-30%); opacity: 0; } }\
          ::view-transition-new(root) { animation: slide-in-from-right 0.4s cubic-bezier(0.32, 0.72, 0, 1); }\
          ::view-transition-old(root) { animation: slide-out-to-left 0.4s cubic-bezier(0.32, 0.72, 0, 1); }\
        ';
        document.head.appendChild(s);
      }
    </script>
  </head>
  <body class="footer-reveal bg-backgroundcolor">
    <main class="w-full sm:w-[90%] mx-auto" transition:name={transitionName}>
      <Header />

      <!-- Hero section: title, metadata, background image -->
      <NotePostHero
        title={title}
        description={description}
        pubDate={pubDate}
        updatedDate={updatedDate}
        heroImage={heroImage}
        tags={tags}
        maturity={maturity}
      />

      <!-- Main content wrapper: overlaps hero on scroll (see note-post-animations.ts) -->
      <div class="note-main-wrapper relative z-10 bg-backgroundcolor">
        <NoteMain>
          <slot />
        </NoteMain>
        <Webmentions url={canonicalURL} />
        <!-- Related notes carousel -->
        <RelatedNotes currentTags={tags} currentTitle={title} seriesPosts={seriesPosts} />
      </div>
    </main>
    <CustomCursor />
    <Footer />
    

    <!-- Scroll animations: hero overlap, fade-out, and zoom (see note-post-animations.ts) -->
    <script>
      import { initNotePostAnimations } from '../scripts/note-post-animations';
      import { initOnLoad } from '../utils/initOnLoad';
      initOnLoad(initNotePostAnimations);
    </script>
  </body>
</html>

<style>
  .note-main-wrapper {
    width: 100vw;
    margin-left: calc((100% - 100vw) / 2);
  }
</style>
