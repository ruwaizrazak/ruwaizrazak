---
import type { CollectionEntry } from 'astro:content';
import { ClientRouter } from 'astro:transitions';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Image from '../components/mdxComponents/Image.astro';
import OtherWorksSection from '../components/OtherWorksSection.astro';

type WorkLayoutProps = CollectionEntry<'works'>['data'] & {
  transitionName?: string;
};

const { title, description, company, duration, role, heroImage, transitionName, phoneImage } = Astro.props as WorkLayoutProps;
const workTransitionStyle = transitionName
  ? `::view-transition-new(${transitionName}){animation:work-scale-in .4s cubic-bezier(.32,.72,0,1)}`
  : '';
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <BaseHead title={title} description={description} />
    <ClientRouter />
    {workTransitionStyle && <style is:global set:html={workTransitionStyle} />}
  </head>
  <body class="footer-reveal bg-backgroundcolor">
    <div class="footer-reveal-content px-20">
      <Header />
      <main transition:name={transitionName}>
        <div>
          <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between mt-20">
            <h1 class="text-syoro font-sans text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-bold leading-tight max-w-3xl">
              {title} <span class="font-normal">| {company}</span>
            </h1>
            <div class="flex flex-col items-center sm:items-end gap-1 my-auto">
              {role && (
                <p class="text-syoro font-sans text-base sm:text-xl md:text-3xl">{role}</p>
              )}
              {duration && (
                <p class="text-syoro font-sans text-base sm:text-lg md:text-2xl uppercase">{duration}</p>
              )}
            </div>
          </div>
        </div>
        <div class="w-full">
          <p class="text-syoro font-serif text-3xl border-l-4 border-syoro pl-4 my-5 w-full lg:w-3/4">{description}</p>
        </div>

        <section class="relative mb-0" id="hero-image-section">
          <div
            class="hero-image-wrapper relative z-0 w-screen max-w-[100vw] ml-[calc(50%-50vw)] content-end overflow-hidden mt-15 inset-shadow-white bg-center bg-cover bg-no-repeat"
            style={heroImage ? `background-image: url(${heroImage})` : undefined}
            id="hero-image"
          />
          {phoneImage && (
            <Image
              src={phoneImage}
              alt=""
              class="relative z-10 w-1/2 h-auto object-cover mx-auto -mt-50"
              loading="eager"
            />
          )}
        </section>

        <article class="work-article text-syoro font-serif text-2xl w-4/5 mx-auto">
          <slot />
        </article>
        <div class="other-works-overlap" data-other-works-wrapper>
          <OtherWorksSection currentSlug={Astro.url.pathname.replace('/works/', '').replace(/\/$/, '')} />
        </div>
      </main>
    </div>
    <Footer />
  </body>
</html>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initHeroScroll() {
    const hero = document.getElementById('hero-image');
    if (!hero || hero.dataset.inited === '1') return;
    hero.dataset.inited = '1';

    let baseH = 0.8 * window.innerHeight;
    const maxBlur = 8;
    let ticking = false;

    function update() {
      if (!hero) return;
      const top = hero.getBoundingClientRect().top;
      const h = Math.max(0, baseH + top);
      hero.style.height = h + 'px';
      const ratio = 1 - h / baseH;
      const blur = Math.max(0, ratio * maxBlur);
      hero.style.filter = blur > 0 ? `blur(${blur}px)` : 'none';
    }

    function onScroll() {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(() => { update(); ticking = false; });
      }
    }

    update();
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', () => { baseH = 0.8 * window.innerHeight; update(); });
  }

  function initOtherWorksOverlap() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const wrapper = document.querySelector<HTMLElement>('[data-other-works-wrapper]');
    if (!wrapper || wrapper.dataset.inited === '1') return;
    wrapper.dataset.inited = '1';

    gsap.to(wrapper, {
      y: -200,
      ease: 'none',
      scrollTrigger: {
        trigger: wrapper,
        start: 'top bottom',
        end: 'top 60%',
        scrub: true,
      },
    });
  }

  function initWorkPage() {
    if (!window.location.pathname.startsWith('/works/')) return;
    initHeroScroll();
    initOtherWorksOverlap();
  }

  document.addEventListener('astro:page-load', initWorkPage);
  if (document.readyState === 'complete') {
    initWorkPage();
  } else {
    window.addEventListener('load', initWorkPage);
  }
</script>

<style>
  #hero-image {
    height: 80vh;
    background-attachment: fixed;
    background-position: center;
    animation: scale-up-hero .8s cubic-bezier(0.4, 0.2, 0.2, 1) forwards;
    transform: scale(0.96);
    opacity: 0.93;
  }
  @keyframes scale-up-hero {
    from { transform: scale(0.5); opacity: 0.5; }
    to   { transform: scale(1);   opacity: 1; }
  }
  .other-works-overlap {
    position: relative;
    z-index: 10;
  }
  .work-article {
    position: relative;
    z-index: 1;
  }
</style>
