---
import type { CollectionEntry } from 'astro:content';
import { ClientRouter } from 'astro:transitions';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Image from '../components/mdxComponents/Image.astro';
import OtherWorksSection from '../components/OtherWorksSection.astro';
import CustomCursor from '../components/CustomCursor.astro';
import { resolveImage } from '../utils/resolveImage';

type WorkLayoutProps = CollectionEntry<'works'>['data'] & {
  transitionName?: string;
};

const { title, description, company, duration, role, heroImage, transitionName, phoneImage, narrativeTitle } = Astro.props as WorkLayoutProps;

// LEARN: Article schema helps search engines show rich snippets for case study pages.
// BaseHead already supports an optional schema prop — we just pass it through.
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: narrativeTitle || title,
  description,
  author: { '@type': 'Person', name: 'Ruwaiz Razak' },
};

// LEARN: Generate the OG image path from the current page URL rather than
// using heroImage. This ensures every work page gets a consistently branded
// social card instead of relying on whatever the hero image happens to be.
const ogImage = `/og${Astro.url.pathname.replace(/\/$/, '')}.png`;

// LEARN: the hero is a CSS background-image, so we use the optimized asset's .src
// (the hashed build URL) instead of the raw /public path. Falls back to the string
// for remote heroes.
const heroImg = resolveImage(heroImage);
const heroImageUrl = heroImg?.src ?? heroImage;

const workTransitionStyle = transitionName
  ? `::view-transition-new(${transitionName}){animation:work-scale-in .4s cubic-bezier(.32,.72,0,1)}`
  : '';
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <BaseHead title={title} description={description} image={ogImage} schema={articleSchema} />
    <ClientRouter />
    {workTransitionStyle && <style is:global set:html={workTransitionStyle} />}
  </head>
  <body class="bg-backgroundcolor">
    <div class="px-10 md:px-12 lg:px-20">
      <Header />
      <main transition:name={transitionName}>
        <!-- Title + metadata header -->
        <div>
          <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between mt-20 mb-10 p-0">
            <h1 class="text-syoro dark:text-syoro font-sans text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-bold leading-none max-w-4xl">
              {title} <span class="font-normal">| {company}</span>
            </h1>
            <div class="flex flex-col items-start md:items-end gap-1 my-auto text-left sm:text-right">
              {role && (
                <p class="text-syoro dark:text-syoro font-sans text-2xl sm:text-xl md:text-2xl lg:text-3xl">{role}</p>
              )}
              {duration && (
                <p class="text-syoro dark:text-syoro font-sans text-xl sm:text-lg md:text-xl  lg:text-2xl uppercase">{duration}</p>
              )}
              
            </div>
          </div>
          
        </div>
        <div class="w-full">
          <p class="text-syoro dark:text-syoro font-serif text-xl sm:text-2xl md:text-3xl border-l-4 border-syoro pl-4 mt-10 mb-20  w-full lg:w-3/4"> {description} </p>
        </div>
        

        <!-- Hero image: shrinks + blurs on scroll (see work-hero-scroll.ts) -->
        <section class="relative mb-0" id="hero-image-section">
          <div
            class="hero-image-wrapper relative z-0 w-screen max-w-[100vw] ml-[calc(50%-50vw)] content-end overflow-hidden mt-15 
            inset-shadow-white bg-center bg-cover bg-no-repeat"
            style={heroImageUrl ? `background-image: url(${heroImageUrl})` : undefined}
            id="hero-image"
          >
          </div>
          {phoneImage && (
            <Image
              src={phoneImage}
              alt=""
              class="relative z-10 w-3/4 md:w-1/2 h-auto object-cover mx-auto -mt-24 md:-mt-50"
              loading="eager"
            />
          )}
          </section>
        
        <!-- Main content (MDX) -->
        <article class="work-article text-syoro font-serif text-xl sm:text-2xl md:text-3xl w-full md:w-4/5 mx-auto">
          <slot />
        </article>
        <!-- Other works: slides up to overlap article on scroll (CSS, see global.css) -->
        <div class="other-works-overlap" data-other-works-wrapper>
          <OtherWorksSection currentSlug={Astro.url.pathname.replace('/works/', '').replace(/\/$/, '')} />
        </div>
      </main>
      
    </div>
    <Footer />
    <CustomCursor />
  </body>
</html>

<!-- Work view analytics event -->
<script>
  import { initWorkView } from '../scripts/analytics';
  import { initOnLoad } from '../utils/initOnLoad';
  initOnLoad(initWorkView);
</script>

<!-- Hero scroll height + blur effect (see work-hero-scroll.ts) -->
<script>
  import { initHeroScrollHeight } from '../scripts/work-hero-scroll';

  function runIfWorkPage() {
    if (window.location.pathname.startsWith('/works/')) {
      initHeroScrollHeight();
    }
  }

  document.addEventListener('astro:page-load', runIfWorkPage);
  if (document.readyState === 'complete') {
    runIfWorkPage();
  } else {
    window.addEventListener('load', runIfWorkPage);
  }
</script>

<!-- "Other works" overlap is now CSS scroll-driven (see .other-works-overlap in global.css) -->

<style>
  #hero-image {
    /* LEARN: Mobile gets 50vh to avoid hero dominating small screens;
       md+ keeps the immersive 80vh. Script mirrors these breakpoints. */
    height: 50vh;
    background-attachment: scroll;
    background-position: center;
    animation: scale-up-hero .8s cubic-bezier(0.4, 0.2, 0.2, 1) forwards;
    transform: scale(1);
    opacity: 0.93;
  }

  /* LEARN: background-attachment:fixed is broken on iOS Safari / mobile Chrome,
     so we only enable it on md+ where it works reliably. */
  @media (min-width: 768px) {
    #hero-image {
      height: 80vh;
      background-attachment: fixed;
    }
  }

  @keyframes scale-up-hero {
    from {
      transform: scale(1);
      opacity: 0.5;
    }
    to {
      transform: scale(1);
      opacity: 1;
    }
  }

  .other-works-overlap {
    position: relative;
    z-index: 10;
  }
  .work-article {
    position: relative;
    z-index: 1;
  }
</style>
