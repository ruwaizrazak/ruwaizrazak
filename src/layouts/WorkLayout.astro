---
import type { CollectionEntry } from 'astro:content';
import { ClientRouter } from 'astro:transitions';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Image from '../components/mdxComponents/Image.astro';

type WorkLayoutProps = CollectionEntry<'works'>['data'] & {
  transitionName?: string;
};

const { title, description, company, duration, role, heroImage, transitionName } = Astro.props as WorkLayoutProps;
const workTransitionStyle = transitionName
  ? `::view-transition-new(${transitionName}){animation:work-scale-in .4s cubic-bezier(.32,.72,0,1)}`
  : '';
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <BaseHead title={title} description={description} />
    <ClientRouter />
    {workTransitionStyle && <style is:global set:html={workTransitionStyle} />}
  </head>
  <body class="footer-reveal bg-backgroundcolor">
    <div class="footer-reveal-content px-20">
      <Header />
      <main class="w-full  mx-auto px-6 sm:px-10 pb-24 pt-8 sm:pt-16" transition:name={transitionName}>
        <!-- Back link: set flag so index skips entrance animations -->
        
        
        <!-- Hero title (Itti-style large headline) -->
         
        <div class="py-8  mt-10 sm:mt-14">
          <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
            <h1 class="text-syoro dark:text-syoro font-sans text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-bold leading-tight max-w-3xl">
              {title} <span class="font-normal">| {company}</span>
            </h1>
            <div class="flex flex-col items-center sm:items-end gap-1 my-auto">
              {role && (
                <p class="text-syoro dark:text-syoro font-sans text-base sm:text-xl md:text-3xl">{role}</p>
              )}
              {duration && (
                <p class="text-syoro dark:text-syoro font-sans text-base sm:text-lg md:text-2xl uppercase">{duration}</p>
              )}
              
            </div>
          </div>
        </div>
        <p class="text-syoro dark:text-syoro font-serif text-3xl border-l-4 border-syoro pl-4 mb-10  w-full lg:w-3/4"> {description} </p>

        <!-- Hero image -->
        {heroImage && (
          <div class="w-full rounded-xl overflow-hidden mb-12 sm:mb-16 shadow-lg">
            <Image
              src={heroImage}
              alt=""
              class="w-full h-auto object-cover"
              loading="eager"
            />
          </div>
        )}
        <!-- Metadata row: ROLE | COMPANY | DURATION -->
        

        <!-- Overview / description -->
        {description && (
          <p class="text-syoro dark:text-syoro font-serif text-lg sm:text-xl leading-relaxed mb-12 sm:mb-16 max-w-3xl">
            {description}
          </p>
        )}

        

        <!-- Main content (MDX) -->
        <article class="prose prose-neutral prose-lg dark:prose-invert max-w-none prose-headings:font-sans prose-p:font-serif prose-p:text-syoro prose-img:rounded-lg prose-img:w-full prose-headings:text-konpeki prose-h4:uppercase prose-h3:uppercase prose-strong:text-pink-500 prose-h5:uppercase prose-h4:font-bold prose-h5:font-bold prose-blockquote:font-handwriting prose-blockquote:leading-auto prose-ul:font-serif prose-li:font-serif prose-ul:list-disc prose-ol:list-decimal prose-blockquote:text-yellow-600 prose-blockquote:italic prose-headings:mb-4 prose-headings:mt-8 first:prose-headings:mt-0">
          <slot />
        </article>
      </main>
    </div>
    <Footer />
  </body>
</html>
