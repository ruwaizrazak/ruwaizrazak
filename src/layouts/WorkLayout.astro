---
import type { CollectionEntry } from 'astro:content';
import { ClientRouter } from 'astro:transitions';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Image from '../components/mdxComponents/Image.astro';
import OtherWorksSection from '../components/OtherWorksSection.astro';

type WorkLayoutProps = CollectionEntry<'works'>['data'] & {
  transitionName?: string;
};

const { title, description, company, duration, role, heroImage, transitionName,phoneImage } = Astro.props as WorkLayoutProps;
const workTransitionStyle = transitionName
  ? `::view-transition-new(${transitionName}){animation:work-scale-in .4s cubic-bezier(.32,.72,0,1)}`
  : '';
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <BaseHead title={title} description={description} />
    <ClientRouter />
    {workTransitionStyle && <style is:global set:html={workTransitionStyle} />}
  </head>
  <body class="footer-reveal bg-backgroundcolor">
    <div class="footer-reveal-content px-20">
      <Header />
      <main transition:name={transitionName}>
        <!-- Back link: set flag so index skips entrance animations -->
        
        
        <!-- Hero title (Itti-style large headline) -->
         
        <div>
          <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between mt-20 mb-10">
            <h1 class="text-syoro dark:text-syoro font-sans text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-bold leading-none max-w-3xl">
              {title} <span class="font-normal">| {company}</span>
            </h1>
            <div class="flex flex-col items-center md:items-end gap-1 my-auto">
              {role && (
                <p class="text-syoro dark:text-syoro font-sans text-base sm:text-xl md:text-3xl">{role}</p>
              )}
              {duration && (
                <p class="text-syoro dark:text-syoro font-sans text-base sm:text-lg md:text-2xl uppercase">{duration}</p>
              )}
              
            </div>
          </div>
        </div>
        <div class="w-full">
          <p class="text-syoro dark:text-syoro font-serif text-3xl border-l-4 border-syoro pl-4 mt-10 mb-20  w-full lg:w-3/4"> {description} </p>
        </div>
        

        <!-- Hero image -->
        <section class="relative mb-0" id="hero-image-section">
          <div
            class="hero-image-wrapper relative z-0 w-screen max-w-[100vw] ml-[calc(50%-50vw)] content-end overflow-hidden mt-15 
            inset-shadow-white bg-center bg-cover bg-no-repeat"
            style={heroImage ? `background-image: url(${heroImage})` : undefined}
            id="hero-image"
          >
          </div>
          {phoneImage && (
            <Image
              src={phoneImage}
              alt=""
              class="relative z-10 w-1/2 h-auto object-cover mx-auto -mt-50"
              loading="eager"
            />
          )}
          </section>
        
        <!-- Overview / description -->
        
        

        

        <!-- Main content (MDX) -->
        <article class="work-article text-syoro font-serif text-2xl w-4/5 mx-auto">
          <slot />
        </article>
        <div class="other-works-overlap" data-other-works-wrapper>
          <OtherWorksSection currentSlug={Astro.url.pathname.replace('/works/', '').replace(/\/$/, '')} />
        </div>
      </main>
      
    </div>
    <Footer />
  </body>
</html>

<script>
  function initHeroScrollHeight() {
    const hero = document.getElementById('hero-image');
    if (!hero || hero.dataset.heroScrollInited === '1') return;
    hero.dataset.heroScrollInited = '1';

    let initialHeightPx = 0.8 * window.innerHeight;
    let ticking = false;
    const maxBlurPx = 8;

    function updateHeight() {
      if (!hero) return;
      const top = hero.getBoundingClientRect().top;
      const heightPx = Math.max(0, initialHeightPx + top);
      hero.style.height = heightPx + 'px';
      const shrinkRatio = 1 - heightPx / initialHeightPx; //(0 when full height, 1 when height is 0).
      const blurPx = Math.max(0,shrinkRatio * maxBlurPx);
      hero.style.filter = blurPx > 0 ? 'blur(' + blurPx + 'px)' : 'none'; //when blurPx > 0, and to 'none' when the hero is at full height.
    }

    function onScroll() {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(function () {
          updateHeight();
          ticking = false;
        });
      }

    }

    function onResize() {
      initialHeightPx = 0.8 * window.innerHeight;
      updateHeight();
    }

    updateHeight();
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onResize);
  }

  function runIfWorkPage() {
    if (window.location.pathname.startsWith('/works/')) {
      initHeroScrollHeight();
    }
  }

  // After view-transition swap (client-side nav to work page)
  document.addEventListener('astro:page-load', runIfWorkPage);

  // Full page load of a work URL (DOM already has #hero-image)
  if (document.readyState === 'complete') {
    runIfWorkPage();
  } else {
    window.addEventListener('load', runIfWorkPage);
  }
</script>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initOtherWorksOverlap() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const wrapper = document.querySelector<HTMLElement>('[data-other-works-wrapper]');
    if (!wrapper || wrapper.dataset.overlapInited === '1') return;
    wrapper.dataset.overlapInited = '1';

    gsap.to(wrapper, {
      y: -200,
      ease: 'none',
      scrollTrigger: {
        trigger: wrapper,
        start: 'top bottom',
        end: 'top 60%',
        scrub: true,
      },
    });
  }

  function runOverlapIfWorkPage() {
    if (window.location.pathname.startsWith('/works/')) {
      initOtherWorksOverlap();
    }
  }

  document.addEventListener('astro:page-load', runOverlapIfWorkPage);
  if (document.readyState === 'complete') {
    runOverlapIfWorkPage();
  } else {
    window.addEventListener('load', runOverlapIfWorkPage);
  }
</script>

<style>
  #hero-image {
    height: 80vh; /* fallback before script runs */
    background-attachment: fixed;
    background-position: center;
    animation: scale-up-hero .8s cubic-bezier(0.4, 0.2, 0.2, 1) forwards;
    transform: scale(1);
    opacity: 0.93;
  }

  @keyframes scale-up-hero {
    from {
      transform: scale(1);
      opacity: 0.5;
    }
    to {
      transform: scale(1);
      opacity: 1;
    }
  }

  .other-works-overlap {
    position: relative;
    z-index: 10;
  }
  .work-article {
    position: relative;
    z-index: 1;
  }
</style>
