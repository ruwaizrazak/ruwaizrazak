---
import { Image } from 'astro:assets';
import { resolveImage } from '../utils/resolveImage';

export interface Props {
  title: string;
  role?: string;
  company: string;
  duration: string;
  heroImage?: string;
  url: string;
}

const { title, role, company, duration, heroImage, url } = Astro.props;
const heroImg = resolveImage(heroImage);
---

<a href={url} class="group block hover:scale-95 transition-all duration-200 ease-in-out">
  <div class="overflow-hidden rounded-lg">
    {heroImg ? (
      <Image src={heroImg} alt={title} class="w-full aspect-[4/3] object-cover" />
    ) : heroImage ? (
      <img src={heroImage} alt={title} class="w-full aspect-[4/3] object-cover" />
    ) : (
      <div class="w-full aspect-[4/3] bg-gray-200 dark:bg-gray-700" />
    )}
  </div>
  <div class="flex flex-col gap-1 mt-4">
    <h3 class="text-syoro font-serif text-xl md:text-2xl lg:text-3xl xl:text-4xl leading-snug group-hover:text-konpeki transition-colors ">
      {title}
    </h3>
    {role && (
      <p class="text-lg md:text-xl lg:text-xl xl:text-2xl font-sans text-syoro/60 dark:text-white/40 uppercase">{role}</p>
    )}
    <p class="text-syoro/60 font-sans text-base md:text-lg uppercase tracking-wide font-semibold dark:text-white/30">
      {company} · {duration}
    </p>
  </div>
</a>
