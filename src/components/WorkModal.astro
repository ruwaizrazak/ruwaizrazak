---
---

<div
  id="work-modal"
  class="fixed inset-0 z-[100] pointer-events-none opacity-0"
  aria-hidden="true">
  <div
    id="work-modal-backdrop"
    class="absolute inset-0 bg-black/60 backdrop-blur-sm opacity-0"
  />
  <div
    id="work-modal-panel"
    class="absolute rounded-2xl overflow-hidden bg-backgroundcolor shadow-2xl flex flex-col"
  >
    <div class="flex-shrink-0 flex items-center justify-between px-4 py-3 border-b border-gray-200 bg-white/95">
      <h2 id="work-modal-title" class="text-lg font-serif font-bold text-syoro truncate pr-4"></h2>
      <button
        id="work-modal-close"
        class="flex-shrink-0 p-2 rounded-full text-syoro hover:bg-yellow-50 transition-colors"
        aria-label="Close"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    <div id="work-modal-content" class="flex-1 min-h-0 overflow-hidden">
      <slot />
    </div>
  </div>
</div>
