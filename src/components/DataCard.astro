---
export interface Props {
  header: string;
  description: string;
  icon: string;
  iconAlt?: string;
  href?: string;
}

const { header, description, icon, iconAlt = header, href } = Astro.props;

const cardClasses = "data-card bg-cardbg border border-card-border shadow-lg rounded-lg p-5 w-full hover:scale-95 transition-all duration-300";
---

{href ? (
  <a href={href} class={`${cardClasses} block`}>
    <div>
      <h3 class="text-xl uppercase">{header}</h3>
      <p>{description}</p>
    </div>
    <img src={icon} alt={iconAlt} class="w-20 h-20 mx-auto py-10 resize" />
    <div class="rotate-180">
      <h3 class="text-xl uppercase">{header}</h3>
      <p>{description}</p>
    </div>
  </a>
) : (
  <div class={cardClasses}>
    <div>
      <h3 class="text-xl uppercase">{header}</h3>
      <p>{description}</p>
    </div>
    <img src={icon} alt={iconAlt} class="w-20 h-20 mx-auto py-10" />
    <div class="rotate-180">
      <h3 class="text-xl uppercase">{header}</h3>
      <p>{description}</p>
    </div>
  </div>
)}
