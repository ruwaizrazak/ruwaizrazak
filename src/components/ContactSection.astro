</div>

<script>
  import gsap from 'gsap';

  function initContactSectionReveal() {
    const section = document.getElementById('Contact');
    if (!section) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            section.classList.add('contact-section-visible');
          }
        });
      },
      { threshold: 0.2, rootMargin: '0px 0px -50px 0px' }
    );

    observer.observe(section);
  }

  function initContactIconMorph() {
    const links = document.querySelectorAll('.contact-link');
    const duration = 0.35;
    const ease = 'power2.inOut';

    links.forEach((link) => {
      const diamond = link.querySelector('.contact-icon-diamond');
      const symbol = link.querySelector('.contact-icon-symbol');
      if (!diamond || !symbol) return;

      link.addEventListener('mouseenter', () => {
        gsap.to(diamond, { opacity: 0, duration, ease });
        gsap.to(symbol, { opacity: 1, duration, ease });
      });

      link.addEventListener('mouseleave', () => {
        gsap.to(diamond, { opacity: 1, duration, ease });
        gsap.to(symbol, { opacity: 0, duration, ease });
      });
    });
  }

  function init() {
    initContactSectionReveal();
    initContactIconMorph();
  }

  document.addEventListener('DOMContentLoaded', init);
  document.addEventListener('astro:page-load', init);
</script>

<style>
  .contact-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-syoro);
    font-family: var(--font-sans);
    font-size: 1.125rem;
    font-weight: 500;
    text-transform: uppercase;
    text-decoration: none;
    white-space: nowrap;
    transition: opacity 0.2s ease;
  }

  .contact-link:hover {
    opacity: 0.8;
  }

  .contact-icon {
    display: block;
    position: relative;
  }

  .contact-icon-diamond {
    opacity: 1;
  }

  .contact-icon-symbol {
    opacity: 0;
  }

  .contact-section-reveal {
    transform: translateY(-40px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }

  .contact-section-reveal.contact-section-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>
