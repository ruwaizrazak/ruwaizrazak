---
import Button from './Button.astro';
import { SOCIAL_LINKS } from '../consts';

---


<div class="contact-section-reveal border-syoro bg-white dark:bg-stone-900 rounded-xl px-10 flex flex-col mt-8 opacity-0" id="Contact">
  <div class="w-full px-10 pt-10">
    <h1 class="text-syoro font-serif text-2xl md:text-4xl w-full sm:w-2/3 md:w-[40%]">Let's get in touch if you are intrigued about my work or just want to say hi!</h1>
    <Button href="/about" variant="primary" class="text-backgroundcolor font-sans text-lg uppercase mt-10">Contact me</Button>
  </div>

  <div class="h-card flex flex-row items-center gap-5 w-full mt-5 mb-2 px-10 py-10 bg-white dark:bg-stone-950 rounded-xl flex-wrap">
    <span class="p-name" hidden>Ruwaiz Razak</span>
    {SOCIAL_LINKS.map((link) => (
      <a href={link.href} target="_blank" rel={link.rel} class={link.class}>
        <svg class={link.svgClass || 'contact-icon w-6 h-6 flex-shrink-0'} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path class="contact-icon-diamond" fill="currentColor" d={link.diamondPath} />
          {link.symbolFill === 'stroke' ? (
            <path class="contact-icon-symbol" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={link.symbolPath} />
          ) : (
            <path class="contact-icon-symbol" fill="currentColor" d={link.symbolPath} />
          )}
        </svg>
        <span>{link.label}</span>
      </a>
    ))}
  </div>
</div>


<script>
  import gsap from 'gsap';

  function initContactSectionReveal() {
    const section = document.getElementById('Contact');
    if (!section) return;

    if (document.body.classList.contains('returned-from-work') || document.documentElement.classList.contains('returned-from-work')) {
      section.classList.add('contact-section-visible');
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            section.classList.add('contact-section-visible');
          }
        });
      },
      { threshold: 0.2, rootMargin: '0px 0px -50px 0px' }
    );

    observer.observe(section);
  }

  function initContactIconMorph() {
    const links = document.querySelectorAll('.contact-link');
    const duration = 0.35;
    const ease = 'power2.inOut';

    links.forEach((link) => {
      const diamond = link.querySelector('.contact-icon-diamond');
      const symbol = link.querySelector('.contact-icon-symbol');
      if (!diamond || !symbol) return;

      link.addEventListener('mouseenter', () => {
        gsap.to(diamond, { opacity: 0, duration, ease });
        gsap.to(symbol, { opacity: 1, duration, ease });
      });

      link.addEventListener('mouseleave', () => {
        gsap.to(diamond, { opacity: 1, duration, ease });
        gsap.to(symbol, { opacity: 0, duration, ease });
      });
    });
  }

  function init() {
    initContactSectionReveal();
    initContactIconMorph();
  }

  import { initOnLoad } from '../utils/initOnLoad';
  initOnLoad(init);
</script>

<style>
  .contact-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-syoro);
    font-family: var(--font-sans);
    font-size: 1.125rem;
    font-weight: 500;
    text-transform: uppercase;
    text-decoration: none;
    white-space: nowrap;
    transition: opacity 0.2s ease;
  }

  .contact-link:hover {
    opacity: 0.8;
  }

  .contact-icon {
    display: block;
    position: relative;
  }

  .contact-icon-diamond {
    opacity: 1;
  }

  .contact-icon-symbol {
    opacity: 0;
  }

  .contact-section-reveal {
    transform: translateY(-40px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }

  .contact-section-reveal.contact-section-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* When returning from work page, show section immediately (html + body for view-transition swap) */
  :global(html.returned-from-work) .contact-section-reveal,
  :global(body.returned-from-work) .contact-section-reveal {
    opacity: 1;
    transform: translateY(0);
  }
</style>