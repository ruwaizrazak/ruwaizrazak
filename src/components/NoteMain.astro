---
import { proseClasses } from '../utils/proseClasses';
---

<div class="note-layout mx-auto flex relative w-full max-w-6xl">

  <!-- TOC Sidebar (desktop > md) -->
  <aside
    class="toc-sidebar hidden md:block md:w-56 lg:w-64 shrink-0 pl-4 relative"
    aria-label="Table of contents"
  >
    <div class="toc-panel sticky top-24 max-h-[80vh] overflow-y-auto pr-4 py-10">
      <p class="text-xs uppercase tracking-widest font-sans text-syoro/40 mb-4">On this page</p>
      <nav>
        <ul id="toc-list" class="space-y-1 list-none p-0 m-0"></ul>
      </nav>
    </div>
  </aside>

  <!-- Mobile edge tab (fixed to viewport left edge) -->
  <button
    class="toc-tab fixed left-0 top-1/2 -translate-y-1/2 z-50 md:hidden
           bg-backgroundcolor border border-syoro/20 rounded-r-lg
           px-1 py-4 flex flex-col items-center gap-1 shadow-sm"
    aria-label="Open table of contents"
    data-toc-toggle
  >
    <svg class="w-4 h-4 text-syoro" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
        d="M4 6h16M4 12h10M4 18h7" />
    </svg>
  </button>

  <!-- Mobile drawer backdrop -->
  <div
    class="toc-backdrop fixed inset-0 z-40 bg-black/40 hidden md:hidden"
    data-toc-backdrop
  ></div>

  <!-- Mobile drawer panel -->
  <div
    class="toc-drawer fixed inset-y-0 left-0 z-50 w-64 bg-backgroundcolor
           shadow-2xl -translate-x-full transition-transform duration-300 ease-in-out md:hidden
           flex flex-col p-6"
    data-toc-drawer
    aria-hidden="true"
  >
    <div class="flex items-center justify-between mb-6">
      <p class="text-xs uppercase tracking-widest font-sans text-syoro/40">On this page</p>
      <button
        class="text-syoro/60 hover:text-syoro transition-colors"
        aria-label="Close table of contents"
        data-toc-close
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    <nav class="overflow-y-auto flex-1">
      <ul id="toc-list-mobile" class="space-y-1 list-none p-0 m-0"></ul>
    </nav>
  </div>

  <!-- Article -->
  <article class={`${proseClasses} py-20 px-10 md:px-12 lg:px-20 w-full min-w-0`}>
    <slot />
  </article>

</div>

<style>
  .note-layout:not([data-has-toc]) .toc-sidebar,
  .note-layout:not([data-has-toc]) .toc-tab {
    display: none;
  }

  [data-toc-drawer] {
    will-change: transform;
  }
</style>

<script>
  function buildTOCList(
    container: HTMLElement,
    headings: Element[],
    onLinkClick: (() => void) | null
  ) {
    container.innerHTML = '';
    headings.forEach((heading) => {
      const id = heading.id;
      const li = document.createElement('li');
      const a = document.createElement('a');
      a.href = `#${id}`;
      a.textContent = heading.textContent ?? '';
      (a as HTMLElement).dataset.tocLink = id;

      const isH3 = heading.tagName === 'H3';
      a.className = [
        'block font-sans text-sm leading-snug transition-colors duration-150 py-0.5',
        isH3
          ? 'pl-4 text-syoro/50 hover:text-syoro'
          : 'text-syoro/70 hover:text-syoro font-medium',
      ].join(' ');

      a.addEventListener('click', (e) => {
        e.preventDefault();
        document.getElementById(id)?.scrollIntoView({ behavior: 'smooth' });
        if (onLinkClick) onLinkClick();
      });

      li.appendChild(a);
      container.appendChild(li);
    });
  }

  function initTOC() {
    const article = document.querySelector('.note-layout article');
    if (!article) return;

    // Move fixed elements to <body> to escape GSAP transform stacking context
    // (GSAP animates .note-main-wrapper with translateY, which breaks fixed positioning)
    const tab = document.querySelector('.toc-tab');
    const drawerEl = document.querySelector('[data-toc-drawer]');
    const backdropEl = document.querySelector('[data-toc-backdrop]');
    if (tab && tab.parentNode !== document.body) document.body.appendChild(tab);
    if (backdropEl && backdropEl.parentNode !== document.body) document.body.appendChild(backdropEl);
    if (drawerEl && drawerEl.parentNode !== document.body) document.body.appendChild(drawerEl);

    // Collect H2/H3, assign IDs if missing
    const rawHeadings = Array.from(article.querySelectorAll('h2, h3'));
    rawHeadings.forEach((h) => {
      if (!h.id) {
        h.id = (h.textContent ?? '')
          .toLowerCase()
          .replace(/\s+/g, '-')
          .replace(/[^\w-]/g, '');
      }
    });
    const headings = rawHeadings.filter((h) => h.id);
    if (headings.length === 0) return;

    // Mark layout as having a TOC (shows sidebar + edge tab)
    document.querySelector('.note-layout')?.setAttribute('data-has-toc', '');

    // Build desktop TOC
    const desktopList = document.getElementById('toc-list');
    if (desktopList) buildTOCList(desktopList, headings, null);

    // Build mobile TOC
    const mobileList = document.getElementById('toc-list-mobile');
    const drawer = document.querySelector('[data-toc-drawer]') as HTMLElement | null;
    const backdrop = document.querySelector('[data-toc-backdrop]') as HTMLElement | null;
    const toggleBtn = document.querySelector('[data-toc-toggle]');
    const closeBtn = document.querySelector('[data-toc-close]');

    function openDrawer() {
      drawer?.classList.remove('-translate-x-full');
      drawer?.setAttribute('aria-hidden', 'false');
      backdrop?.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }
    function closeDrawer() {
      drawer?.classList.add('-translate-x-full');
      drawer?.setAttribute('aria-hidden', 'true');
      backdrop?.classList.add('hidden');
      document.body.style.overflow = '';
    }

    if (mobileList) buildTOCList(mobileList, headings, closeDrawer);

    toggleBtn?.addEventListener('click', openDrawer);
    closeBtn?.addEventListener('click', closeDrawer);
    backdrop?.addEventListener('click', closeDrawer);

    // Scroll spy via IntersectionObserver
    function setActive(id: string) {
      document.querySelectorAll('[data-toc-link]').forEach((a) => {
        const el = a as HTMLElement;
        const isActive = el.dataset.tocLink === id;
        el.classList.toggle('!text-syoro', isActive);
        el.classList.toggle('font-semibold', isActive);
      });
    }

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries.filter((e) => e.isIntersecting);
        if (visible.length === 0) return;
        const top = visible.reduce((a, b) =>
          a.boundingClientRect.top < b.boundingClientRect.top ? a : b
        );
        setActive(top.target.id);
      },
      { rootMargin: '0px 0px -60% 0px', threshold: 0 }
    );

    headings.forEach((h) => observer.observe(h));
  }

  document.addEventListener('astro:page-load', initTOC);
  if (document.readyState !== 'loading') initTOC();
  else document.addEventListener('DOMContentLoaded', initTOC);
</script>
