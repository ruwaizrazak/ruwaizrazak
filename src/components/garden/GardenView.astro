---
import Header from '../Header.astro';
import GardenIntro from './GardenIntro.astro';
import GardenStickyBar from './GardenStickyBar.astro';
import GardenCards from './GardenCards.astro';
import GardenStrip from './GardenStrip.astro';

interface Props {
  title: string;
  description: string;
  posts: any[];
  sortedTags: string[];
  wideFullRow?: boolean;
}
const { title, description, posts, sortedTags, wideFullRow = false } = Astro.props;
---

<Header />
<main>
  <GardenIntro title={title} description={description} />
  <!-- <GardenStickyBar title={title} sortedTags={sortedTags} /> -->
  <GardenCards posts={posts} wideFullRow={wideFullRow} />
</main>
<GardenStrip posts={posts} />
