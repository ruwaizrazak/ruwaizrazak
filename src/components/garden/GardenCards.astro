---
import ContentCard from '../ContentCard.astro';

interface Props {
  posts: any[];
}
const { posts } = Astro.props;

const cardVariantCollections = new Set(['essays', 'playground']);
---

<section class="garden-cards-section px-5 md:px-10 pb-40">
  <div class="card-masonry columns-1 md:columns-2 lg:columns-3 2xl:columns-4 gap-6">
    {posts?.map((post) => (
      <div
        class="garden-card-item post-item break-inside-avoid mb-6 card-reveal"
        data-tags={post.data.tags?.join(' ')}
        data-collection={post.collection}
      >
        <ContentCard
          title={post.data.title}
          description={post.data.description || ''}
          pubDate={post.data.pubDate}
          url={`/${post.collection}/${post.id}/`}
          heroImage={cardVariantCollections.has(post.collection) ? post.data.heroImage : undefined}
          maturity={post.data.maturity}
          collection={post.collection}
          variant={cardVariantCollections.has(post.collection) ? 'card' : 'compact'}
        />
      </div>
    ))}
  </div>
</section>

<style is:global>
  .card-reveal {
    transition: opacity 0.15s ease;
  }
</style>

<script>
  import { initOnLoad } from '../../utils/initOnLoad';

  function initCardReveal() {
    const cards = document.querySelectorAll<HTMLElement>('.card-reveal');
    if (!cards.length) return;

    function updateOpacities() {
      const vh = window.innerHeight;
      cards.forEach((card) => {
        const rect = card.getBoundingClientRect();
        const cardCenter = rect.top + rect.height / 2;

        if (cardCenter <= vh / 2) {
          card.style.opacity = '1';
        } else if (cardCenter >= vh) {
          card.style.opacity = '0.8';
        } else {
          const t = (cardCenter - vh / 2) / (vh / 2);
          card.style.opacity = String(1 - 0.4 * t);
        }
      });
    }

    updateOpacities();
    window.addEventListener('scroll', updateOpacities, { passive: true });
  }

  initOnLoad(initCardReveal);
</script>
