---
import NoteCard from '../NoteCard.astro';
import EssayCard from '../EssayCard.astro';

interface Props {
  posts: any[];
}
const { posts } = Astro.props;
---

<section class="garden-cards-section px-5 md:px-10 pb-40">
  <div class="card-masonry columns-1 md:columns-2 lg:columns-3 2xl:columns-4 gap-6">
    {posts?.map((post) => (
      <div
        class="garden-card-item post-item break-inside-avoid mb-6"
        data-tags={post.data.tags?.join(' ')}
        data-collection={post.collection}
      >
        {post.collection === 'essays' ? (
          <EssayCard
            title={post.data.title}
            description={post.data.description || ''}
            pubDate={post.data.pubDate}
            url={`/essays/${post.id}/`}
            heroImage={post.data.heroImage}
            maturity={post.data.maturity}
          />
        ) : (
          <NoteCard
            title={post.data.title}
            description={post.data.description || ''}
            pubDate={post.data.pubDate}
            url={`/${post.collection}/${post.id}/`}
            maturity={post.data.maturity}
          />
        )}
      </div>
    ))}
  </div>
</section>
