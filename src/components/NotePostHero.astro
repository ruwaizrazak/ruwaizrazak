---
import { getMaturityIcon } from '../utils/maturityIcons';
import PageHero from './PageHero.astro';


interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  tags: string[];
  maturity?: 'seed' | 'plant' | 'tree';
}

const { title, description, pubDate, updatedDate, heroImage, tags = [], maturity } = Astro.props;
const maturityIcon = getMaturityIcon(maturity);

const formattedDate = pubDate.toLocaleDateString('en-us', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
const formattedUpdatedDate = updatedDate?.toLocaleDateString('en-us', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<PageHero title={title} description={description} titleClass="p-name" descriptionClass="p-summary" class="justify-start mb-10">
  <!-- Metadata row -->
  <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-lg font-sans uppercase text-syoro/60 mb-4 mt-10">
    {maturityIcon && (
      <div class="flex items-center gap-1.5">
        <img src={maturityIcon} class="w-4 opacity-60" alt="" />
        <span>{maturity}</span>
      </div>
    )}
    <time datetime={pubDate.toISOString()} class="dt-published">{formattedDate}</time>
    {formattedUpdatedDate && (
      <span>· Updated {formattedUpdatedDate}</span>
    )}
  </div>

  <!-- Tags -->
  {tags.length > 0 && (
    <div class="flex flex-wrap items-center gap-x-1 text-lg font-sans text-syoro/60">
      {tags.map((tag, index) => (
        <>
          <a
            href={`/tags/${tag.toLowerCase()}`}
            class="hover:text-syoro/80 transition-colors duration-200 hover:italic"
          >
            {tag.charAt(0).toUpperCase() + tag.slice(1)}
          </a>
          {index < tags.length - 1 && <span>·</span>}
        </>
      ))}
    </div>
  )}

  <!-- Hero image, clean and simple -->
  {heroImage && (
    <img
      src={heroImage}
      alt=""
      class="w-full mt-12 rounded"
      loading="eager"
    />
  )}
</PageHero>
