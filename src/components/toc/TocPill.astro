---
// LEARN: Floating bottom-center TOC pill. Single component replaces both the
// old desktop sidebar and the old mobile drawer. Markup is intentionally minimal
// — the script in src/scripts/toc.ts owns rendering the list, scroll-spy
// highlighting, the odometer label, and the GSAP open/close timeline.
//
// The pill intentionally INVERTS from the page theme so it always reads as a
// floating overlay: dark pill on light page, light pill on dark page. Color
// tokens are managed via dark: Tailwind variants and the --toc-fg-rgb custom
// property (used by the active-row pulse animation).
//
// Width comes from CSS custom properties so it scales responsively at lg/xl.
// Hidden by default; initTOC() removes [hidden] only if the article has headings.
---

<!-- LEARN: the pill splits into TWO layers to dodge two iOS Safari WebKit bugs
     that both stem from putting `backdrop-filter` on this container:
       1. Hit-testing breaks on/inside a position:fixed element carrying
          backdrop-filter — the toggle button eats taps but never fires, so
          the pill reads as "not expandable" on iPhone.
       2. backdrop-filter + overflow-hidden + border-radius fails to clip the
          blur to the rounded corners, so the pill renders with square corners.
     Fix: the interactive container stays backdrop-filter-FREE (so taps reach
     the button and its own border-radius/overflow clip the panel normally),
     and a non-interactive [data-toc-bg] layer behind the content owns the
     blur + tint + shadow. Taps never touch a backdrop-filter surface. -->
<div
  data-toc-pill
  hidden
  class="group fixed bottom-6 left-1/2 -translate-x-1/2 z-50
         flex flex-col items-stretch
         text-white dark:text-black
         ring-1 ring-white/10 dark:ring-black/10
         overflow-hidden
         max-w-[calc(100vw-1.5rem)]
         shadow-[0_8px_32px_rgb(0_0_0_/_0.35),0_0_40px_rgb(255_255_255_/_0.05)]
         dark:shadow-[0_8px_32px_rgb(0_0_0_/_0.45),0_0_40px_rgb(0_0_0_/_0.08)]"
  style="width: var(--toc-w-compact);"
>
  <!-- LEARN: backdrop layer — absolutely positioned behind the content and
       pointer-events-none so it's off the tap path. `border-radius: inherit`
       tracks the container's GSAP-animated radius (9999px ↔ 16px) with no JS.
       Only the blur + tint live here; the shadow stays on the container so the
       container's own overflow-hidden doesn't clip it (a parent clips a
       child's box-shadow, but never its own). -->
  <div
    data-toc-bg
    aria-hidden="true"
    class="absolute inset-0 -z-10 pointer-events-none
           bg-black/85 dark:bg-white/85 backdrop-blur-md"
  ></div>
  <!-- Expanded panel — script GSAP-animates height/opacity (order-first stacks it above the toggle button in flex layout). The "On this page" title now lives in the toggle bar when expanded, so the panel is just the heading list bracketed by gradient lines. -->
  <nav
    data-toc-panel
    id="toc-panel"
    aria-label="Table of contents"
    aria-hidden="true"
    class="hidden order-first">
    <div class="relative">
      <!-- gradient line top -->
      <div
        aria-hidden="true"
        class="pointer-events-none absolute inset-x-0 top-0 h-px z-10
               bg-gradient-to-r from-transparent via-white/25 dark:via-black/25 to-transparent"
      ></div>

      <!-- LEARN: space-y removed so adjacent rows' rail ::before pseudo-elements
           butt against each other into one continuous vertical line. Button
           py-2 still provides vertical rhythm between slot centers. -->
      <ul
        data-toc-list
        class="list-none p-0 m-0
               h-56 overflow-y-auto scroll-smooth px-1.5 py-2"
      ></ul>

      <!-- gradient line bottom -->
      <div
        aria-hidden="true"
        class="pointer-events-none absolute inset-x-0 bottom-0 h-px z-10
               bg-gradient-to-r from-transparent via-white/25 dark:via-black/25 to-transparent"
      ></div>
    </div>
  </nav>

  <button
    type="button"
    data-toc-toggle
    aria-expanded="false"
    aria-controls="toc-panel"
    aria-label="Table of contents"
    class="flex items-center gap-2 px-4 py-2.5
           text-base font-sans text-white/90 hover:text-white dark:text-black/90 dark:hover:text-black
           focus:outline-none focus-visible:ring-2 focus-visible:ring-white/30 dark:focus-visible:ring-black/30 rounded-full
           motion-safe:active:scale-95 motion-safe:transform-gpu
           touch-manipulation transition-transform duration-150
           cursor-pointer"
  >
    <!-- LEARN: pulsating "current section" dot. Same keyframe drives the
         active-row in-slot dot so the indicator reads as one continuous
         signal across the morph. bg-current = theme-aware.
         `motion-safe:` variant gates the animation off in reduce-motion mode
         (no separate media-query override needed). The `.toc-dot` class
         survives only as a selector hook for the expanded-state hide rule. -->
    <span
      class="toc-dot inline-block w-1.5 h-1.5 rounded-full bg-current shrink-0
             shadow-[0_0_6px_0_currentColor]
             motion-safe:animate-[toc-dot-pulse_1.6s_ease-in-out_infinite]"
      aria-hidden="true"
    ></span>
    <!-- Middle slot — stacks two layers in the same flex cell:
         (1) [data-toc-current]: odometer label showing the current heading name, visible when collapsed.
         (2) [data-toc-static-label]: static "On this page" title, visible when expanded.
         Opacity crossfade via [data-expanded] (CSS below). h-6 matches text-base line height. -->
    <span class="relative flex-1 min-w-0 h-6">
      <span
        data-toc-current
        class="absolute pl-5 inset-0 overflow-hidden text-left"
      ></span>
      <span
        data-toc-static-label
        class="absolute inset-0 flex items-center text-left"
      >On this page</span>
    </span>
    <svg
      data-toc-chevron
      class="w-3.5 h-3.5 shrink-0 opacity-70"
      fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"
    >
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
    </svg>
  </button>
</div>

<style>
  /*
   * LEARN: responsive width custom properties — toc.ts reads these at animation
   * time via getComputedStyle, so resizing across breakpoints picks up new
   * values on the next open/close without a JS resize listener.
   *
   * --toc-fg-rgb is a foreground RGB triplet (no alpha) used by the active-row
   * pulse animation in toc.ts. Flipping it with .dark keeps the pulse on-theme
   * without any JS branching.
   */
  [data-toc-pill] {
    --toc-w-compact: 14rem;
    --toc-w-expanded: 22rem;
    --toc-fg-rgb: 255 255 255;
    /* LEARN: explicit finite radius instead of Tailwind `rounded-full`
       (= calc(infinity * 1px)), which iOS Safari can drop → 0 → square
       corners on first paint / reduce-motion before GSAP's set runs. GSAP
       still animates this inline (9999px ↔ 16px) on open/close. */
    border-radius: 9999px;
  }

  /* LEARN: backdrop layer inherits the container's animated radius, and the
     -webkit-mask forces iOS Safari to actually clip the backdrop-filter to
     those rounded corners (the classic overflow-hidden + border-radius +
     backdrop-filter clip bug). Harmless no-op on browsers that already clip. */
  [data-toc-bg] {
    border-radius: inherit;
    -webkit-mask-image: -webkit-radial-gradient(white, black);
  }
  :where(.dark) [data-toc-pill] {
    --toc-fg-rgb: 0 0 0;
  }
  @media (min-width: 1024px) {  /* lg */
    [data-toc-pill] {
      --toc-w-compact: 16rem;
      --toc-w-expanded: 26rem;
    }
  }
  @media (min-width: 1280px) {  /* xl */
    [data-toc-pill] {
      --toc-w-compact: 18rem;
      --toc-w-expanded: 30rem;
    }
  }

  /*
   * LEARN: shadow now lives in Tailwind arbitrary `shadow-[…]` utilities on
   * the wrapper div (with a `dark:shadow-[…]` variant). Folded out of CSS so
   * we don't keep a custom class around just for two box-shadow declarations.
   */

  /*
   * LEARN: timeline-style slot indicator. Every list row has an outlined ring
   * at the left edge. Only the active row's slot contains the pulsating inner
   * dot (rendered via ::after). This is the single visual signal for "current"
   * — no bg-tint, no bold weight needed.
   */
  @keyframes toc-dot-pulse {
    0%, 100% { opacity: 0.55; transform: scale(0.85); }
    50%      { opacity: 1;    transform: scale(1); }
  }

  .toc-slot {
    display: inline-block;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 1px solid currentColor;
    position: relative;
    flex-shrink: 0;
    opacity: 0.4;
    transition: opacity 200ms ease-out;
  }
  [data-toc-link]:hover .toc-slot {
    opacity: 0.7;
  }
  /* LEARN: persistent background tint on the current row. Uses --toc-fg-rgb
     so the hue is right on both light and dark pills with no override. 0.08
     sits a hair above the 5% hover tint so the active state reads as "sticky"
     rather than "transient hover". Button's rounded-lg shapes the fill. */
  [data-toc-link][data-active] {
    background-color: rgb(var(--toc-fg-rgb) / 0.08);
  }
  [data-toc-link][data-active] .toc-slot {
    opacity: 1;
    /* LEARN: alpha-free border so the active ring reads at full theme color,
       not inherited 50% alpha from the button's text-white/50 currentColor. */
    border-color: rgb(var(--toc-fg-rgb));
  }
  [data-toc-link][data-active] .toc-slot::after {
    content: '';
    position: absolute;
    /* LEARN: inset 1 → 8×8 dot inside the 10×10 ring (was 6×6, too small to
       read at this scale). */
    inset: 1px;
    border-radius: 50%;
    /* LEARN: use the pill's theme-aware foreground RGB triplet (no alpha)
       so the dot pulses at full opacity. currentColor here would inherit
       the button's text-white/50 (or text-black/50) and render at ~50%
       even at the keyframe peak — invisible against the translucent pill. */
    background: rgb(var(--toc-fg-rgb));
    box-shadow: 0 0 6px 1px rgb(var(--toc-fg-rgb) / 0.7);
    animation: toc-dot-pulse 1.6s ease-in-out infinite;
  }

  /*
   * LEARN: vertical timeline rail. Each row draws its own 1px line at the
   * slot's horizontal center, top-to-bottom; with space-y removed on the ul
   * these butt into one continuous line. Default opacity reads as "bright"
   * (above-active + active rows); the :has(...) ~ sibling rule below dims
   * rows that come AFTER the active one. left = button px-3 (12px) + half
   * the 10px slot - half the 1px line = 16.5px from the button's left edge.
   */
  [data-toc-link] {
    position: relative;
  }
  [data-toc-link]::before {
    content: '';
    position: absolute;
    left: calc(0.75rem + 5px - 0.5px);
    top: 0;
    bottom: 0;
    width: 1px;
    background: currentColor;
    opacity: 0.5;
    pointer-events: none;
  }
  /* Trim the rail so it starts/ends at the first/last slot's center,
     not at the row edges — otherwise the rail visibly overshoots. */
  [data-toc-list] li:first-child [data-toc-link]::before { top: 50%; }
  [data-toc-list] li:last-child  [data-toc-link]::before { bottom: 50%; }

  /* Rows AFTER the active row → faint rail (the path not yet walked).
     :has(...) ~ li selects every sibling li that follows the active one. */
  [data-toc-list] li:has([data-toc-link][data-active]) ~ li [data-toc-link]::before {
    opacity: 0.15;
  }

  /*
   * LEARN: "passed" slot state. Rows ABOVE the active row are headings the
   * reader has scrolled past — fill their slots with a solid dot (no pulse).
   * Only the active row pulses, so the live cue stays unambiguous.
   * Selector: li that has a later sibling containing the active link.
   */
  [data-toc-list] li:has(~ li [data-toc-link][data-active]) .toc-slot {
    opacity: 1;
  }
  [data-toc-list] li:has(~ li [data-toc-link][data-active]) .toc-slot::after {
    content: '';
    position: absolute;
    inset: 2px;
    border-radius: 50%;
    background: currentColor;
  }

  /* Upcoming rows → fainter ring so the progress hierarchy reads at a glance. */
  [data-toc-list] li:has([data-toc-link][data-active]) ~ li .toc-slot {
    opacity: 0.3;
  }

  /*
   * LEARN: pulsating dot in the collapsed pill's toggle bar — animation +
   * shadow now live as Tailwind utilities directly on the <span>:
   *   motion-safe:animate-[toc-dot-pulse_1.6s_ease-in-out_infinite]
   *   shadow-[0_0_6px_0_currentColor]
   * The `.toc-dot` class name survives only so [data-expanded] can pin the
   * dot to opacity:0 during the morph (see crossfade block below).
   *
   * The reduced-motion override stays for the in-slot active dot only,
   * because pseudo-elements (::after) can't be reached by Tailwind variants.
   */
  @media (prefers-reduced-motion: reduce) {
    [data-toc-link][data-active] .toc-slot::after {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }

  /*
   * LEARN: middle-slot crossfade.
   *  Collapsed: pulsating dot + current-heading odometer visible, static label hidden.
   *  Expanded:  dot + odometer hidden, static "On this page" title visible.
   * Same flex slot for both labels (absolute siblings in a relative wrapper),
   * so the chevron stays anchored at the right edge throughout the morph.
   * The dot also hides when expanded — its semantic role ("you're in section X")
   * doesn't fit a generic title; the dot continues to do its job in the list.
   */
  [data-toc-pill] [data-toc-current],
  [data-toc-pill] [data-toc-static-label],
  [data-toc-pill] .toc-dot {
    transition: opacity 180ms ease-out;
  }
  [data-toc-pill] [data-toc-static-label] {
    opacity: 0;
    pointer-events: none;
  }
  [data-toc-pill][data-expanded] [data-toc-current] {
    opacity: 0;
    pointer-events: none;
  }
  [data-toc-pill][data-expanded] [data-toc-static-label] {
    opacity: 1;
    pointer-events: auto;
  }
  [data-toc-pill][data-expanded] .toc-dot {
    opacity: 0;
    animation: none;
  }
</style>
